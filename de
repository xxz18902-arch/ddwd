-- ─── Section ─────────────────────────────────────────────────────────────────
-- Returns a builder object so you can do: local s = UI:AddSection(page, "Combat")
--   s:Toggle("Aimbot", cb)   s:Slider("Speed", 0, 100, 50, cb)   etc.
function Elements.Section(parent, title)
    local section = New("Frame", {
        Name = title .. "Section",
        BackgroundColor3 = C.Surface,
        BorderSizePixel = 0,
        Size = UDim2.new(1, 0, 0, 0),
        AutomaticSize = Enum.AutomaticSize.Y,
        ZIndex = 10,
    }, parent)
    New("UICorner", { CornerRadius = UDim.new(0, 6) }, section)
    New("UIStroke", { Color = C.Border, Thickness = 1, ApplyStrokeMode = Enum.ApplyStrokeMode.Border }, section)

    local header = New("Frame", {
        Name = "Header",
        BackgroundTransparency = 1,
        Size = UDim2.new(1, 0, 0, 36),
        ZIndex = 11,
    }, section)

    New("TextLabel", {
        BackgroundTransparency = 1,
        Position = UDim2.new(0, 14, 0, 0),
        Size = UDim2.new(1, -28, 1, 0),
        Font = Enum.Font.GothamBold,
        Text = string.upper(title),
        TextColor3 = C.TextSecondary,
        TextSize = 11,
        TextXAlignment = Enum.TextXAlignment.Left,
        ZIndex = 12,
    }, header)

    New("Frame", {
        Name = "Line",
        BackgroundColor3 = C.Border,
        BorderSizePixel = 0,
        Position = UDim2.new(0, 14, 1, -1),
        Size = UDim2.new(1, -28, 0, 1),
        ZIndex = 11,
    }, header)

    local content = New("Frame", {
        Name = "Content",
        BackgroundTransparency = 1,
        Position = UDim2.new(0, 0, 0, 36),
        Size = UDim2.new(1, 0, 0, 0),
        AutomaticSize = Enum.AutomaticSize.Y,
        ZIndex = 10,
    }, section)
    New("UIListLayout", { SortOrder = Enum.SortOrder.LayoutOrder, Padding = UDim.new(0, 8) }, content)
    New("UIPadding", {
        PaddingLeft   = UDim.new(0, 14),
        PaddingRight  = UDim.new(0, 14),
        PaddingTop    = UDim.new(0, 10),
        PaddingBottom = UDim.new(0, 14),
    }, content)

    -- Builder object
    local builder = { _content = content }

    function builder:Toggle(text, callback) return Elements.Toggle(content, text, callback) end
    function builder:Slider(text, min, max, default, callback) return Elements.Slider(content, text, min, max, default, callback) end
    function builder:Dropdown(text, options, default, callback) return Elements.Dropdown(content, text, options, default, callback) end
    function builder:Button(text, callback, style) return Elements.Button(content, text, callback, style) end
    function builder:TextBox(text, placeholder, callback) return Elements.TextBox(content, text, placeholder, callback) end
    function builder:KeyPicker(text, defaultKey, callback) return Elements.KeyPicker(content, text, defaultKey, callback) end
    function builder:ColorPicker(text, default, callback) return Elements.ColorPicker(content, text, default, callback) end
    function builder:ProgressBar(text, initial) return Elements.ProgressBar(content, text, initial) end
    function builder:Label(text, color) return Elements.Label(content, text, color) end
    function builder:Separator() return Elements.Separator(content) end

    return builder
end

-- ─── Toggle ──────────────────────────────────────────────────────────────────
-- FIX: external Set() no longer blocked by interacting guard
function Elements.Toggle(parent, text, callback)
    callback = callback or function() end
    local toggled = false
    local animating = false

    local frame = New("Frame", {
        Name = text .. "Toggle",
        BackgroundTransparency = 1,
        Size = UDim2.new(1, 0, 0, 32),
        ZIndex = 15,
    }, parent)

    local label = New("TextLabel", {
        BackgroundTransparency = 1,
        Size = UDim2.new(1, -60, 1, 0),
        Font = Enum.Font.Gotham,
        Text = text,
        TextColor3 = C.TextPrimary,
        TextSize = 13,
        TextXAlignment = Enum.TextXAlignment.Left,
        ZIndex = 16,
    }, frame)

    local track = New("Frame", {
        BackgroundColor3 = C.Border,
        BorderSizePixel = 0,
        Position = UDim2.new(1, -52, 0.5, -10),
        Size = UDim2.new(0, 44, 0, 20),
        ZIndex = 16,
    }, frame)
    New("UICorner", { CornerRadius = UDim.new(1, 0) }, track)

    local circle = New("Frame", {
        BackgroundColor3 = Color3.fromRGB(220, 220, 220),
        BorderSizePixel = 0,
        Position = UDim2.new(0, 2, 0.5, -8),
        Size = UDim2.new(0, 16, 0, 16),
        ZIndex = 17,
    }, track)
    New("UICorner", { CornerRadius = UDim.new(1, 0) }, circle)

    local clickArea = New("TextButton", {
        BackgroundTransparency = 1,
        Size = UDim2.new(1, 0, 1, 0),
        Text = "",
        ZIndex = 18,
    }, frame)

    -- FIX: animate is separate from the external Set path
    local function animate(state)
        local dur = 0.18
        if state then
            Aether.Tween(track,  dur, Enum.EasingStyle.Sine, Enum.EasingDirection.Out, { BackgroundColor3 = C.Success })
            Aether.Tween(circle, dur, Enum.EasingStyle.Sine, Enum.EasingDirection.Out, { Position = UDim2.new(1, -18, 0.5, -8) })
            Aether.Tween(label,  dur, Enum.EasingStyle.Sine, Enum.EasingDirection.Out, { TextColor3 = C.Success })
        else
            Aether.Tween(track,  dur, Enum.EasingStyle.Sine, Enum.EasingDirection.Out, { BackgroundColor3 = C.Border })
            Aether.Tween(circle, dur, Enum.EasingStyle.Sine, Enum.EasingDirection.Out, { Position = UDim2.new(0, 2, 0.5, -8) })
            Aether.Tween(label,  dur, Enum.EasingStyle.Sine, Enum.EasingDirection.Out, { TextColor3 = C.TextPrimary })
        end
    end

    local function setState(state, skipCallback)
        if animating then return end
        animating = true
        toggled = state
        animate(state)
        task.delay(0.2, function() animating = false end)
        if not skipCallback then pcall(callback, toggled) end
    end

    clickArea.MouseButton1Click:Connect(function()
        setState(not toggled)
    end)

    -- FIX: external Set bypasses animating guard
    return {
        Set = function(_, v)
            toggled = (v == true)
            animate(toggled)
            pcall(callback, toggled)
        end,
        Get = function() return toggled end,
        Frame = frame,
    }
end

-- ─── Slider ──────────────────────────────────────────────────────────────────
-- FIX: valueBox display stays in sync with clamped value; added padding on box
function Elements.Slider(parent, text, min, max, default, callback)
    min     = min     or 0
    max     = max     or 100
    default = math.clamp(default or min, min, max)
    callback = callback or function() end
    local dragging = false
    local currentValue = default

    local frame = New("Frame", {
        Name = text .. "Slider",
        BackgroundTransparency = 1,
        Size = UDim2.new(1, 0, 0, 50),
        ZIndex = 15,
    }, parent)

    New("TextLabel", {
        BackgroundTransparency = 1,
        Size = UDim2.new(0.55, 0, 0, 22),
        Font = Enum.Font.Gotham,
        Text = text,
        TextColor3 = C.TextPrimary,
        TextSize = 13,
        TextXAlignment = Enum.TextXAlignment.Left,
        ZIndex = 16,
    }, frame)

    local valueBox = New("TextBox", {
        BackgroundColor3 = C.Background,
        BorderSizePixel = 0,
        Position = UDim2.new(1, -56, 0, 1),
        Size = UDim2.new(0, 52, 0, 20),
        Font = Enum.Font.Gotham,
        Text = tostring(default),
        TextColor3 = C.TextPrimary,
        TextSize = 12,
        ClearTextOnFocus = false,
        ZIndex = 16,
    }, frame)
    New("UICorner", { CornerRadius = UDim.new(0, 4) }, valueBox)
    New("UIPadding", { PaddingLeft = UDim.new(0, 5), PaddingRight = UDim.new(0, 5) }, valueBox)
    local boxStroke = New("UIStroke", { Color = C.Border, Thickness = 1 }, valueBox)

    local track = New("Frame", {
        BackgroundColor3 = C.SurfaceActive,
        BorderSizePixel = 0,
        Position = UDim2.new(0, 0, 0, 34),
        Size = UDim2.new(1, 0, 0, 5),
        ZIndex = 16,
    }, frame)
    New("UICorner", { CornerRadius = UDim.new(1, 0) }, track)

    local fillPct = (default - min) / math.max(max - min, 1)

    local fill = New("Frame", {
        BackgroundColor3 = C.AccentOrange,
        BorderSizePixel = 0,
        Size = UDim2.new(fillPct, 0, 1, 0),
        ZIndex = 17,
    }, track)
    New("UICorner", { CornerRadius = UDim.new(1, 0) }, fill)
    New("UIGradient", {
        Color = ColorSequence.new({
            ColorSequenceKeypoint.new(0, C.AccentOrange),
            ColorSequenceKeypoint.new(1, C.AccentPurple),
        }),
        Rotation = 0,
    }, fill)

    local thumb = New("Frame", {
        BackgroundColor3 = Color3.fromRGB(245, 245, 245),
        BorderSizePixel = 0,
        Position = UDim2.new(fillPct, -7, 0.5, -7),
        Size = UDim2.new(0, 14, 0, 14),
        ZIndex = 18,
    }, track)
    New("UICorner", { CornerRadius = UDim.new(1, 0) }, thumb)
    New("UIStroke", { Color = C.AccentOrange, Thickness = 2 }, thumb)

    local function setVisuals(scale, value)
        fill.Size = UDim2.new(scale, 0, 1, 0)
        thumb.Position = UDim2.new(scale, -7, 0.5, -7)
        valueBox.Text = tostring(value)
        currentValue = value
    end

    local function updateFromX(posX)
        local scale = math.clamp((posX - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
        local value = math.floor(scale * (max - min) + min)
        setVisuals(scale, value)
        pcall(callback, value)
    end

    thumb.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            Aether.Tween(thumb, 0.1, nil, nil, { Size = UDim2.new(0, 16, 0, 16) })
        end
    end)
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 and dragging then
            dragging = false
            Aether.Tween(thumb, 0.1, nil, nil, { Size = UDim2.new(0, 14, 0, 14) })
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            updateFromX(input.Position.X)
        end
    end)
    track.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            updateFromX(input.Position.X)
        end
    end)

    valueBox.Focused:Connect(function()
        Aether.Tween(boxStroke, 0.2, nil, nil, { Color = C.AccentOrange })
    end)
    valueBox.FocusLost:Connect(function()
        Aether.Tween(boxStroke, 0.2, nil, nil, { Color = C.Border })
        -- FIX: clamp, then sync display and internal state together
        local num = math.clamp(tonumber(valueBox.Text) or currentValue, min, max)
        local scale = (num - min) / math.max(max - min, 1)
        setVisuals(scale, num)
        pcall(callback, num)
    end)

    return {
        Set = function(_, v)
            v = math.clamp(v, min, max)
            local scale = (v - min) / math.max(max - min, 1)
            setVisuals(scale, v)
        end,
        Get = function() return currentValue end,
        Frame = frame,
    }
end

-- ─── Dropdown ────────────────────────────────────────────────────────────────
-- FIX: list frame tween uses scale=1 relative to its own parent, not 0.52
function Elements.Dropdown(parent, text, options, default, callback)
    options  = options  or {}
    callback = callback or function() end
    local selected = (type(default) == "string" and default)
                     or options[default or 1]
                     or options[1]
                     or "None"
    local open = false

    local frame = New("Frame", {
        Name = text .. "Dropdown",
        BackgroundTransparency = 1,
        Size = UDim2.new(1, 0, 0, 32),
        ZIndex = 20,
        ClipsDescendants = false,
    }, parent)

    New("TextLabel", {
        BackgroundTransparency = 1,
        Size = UDim2.new(0.45, 0, 1, 0),
        Font = Enum.Font.Gotham,
        Text = text,
        TextColor3 = C.TextPrimary,
        TextSize = 13,
        TextXAlignment = Enum.TextXAlignment.Left,
        ZIndex = 21,
    }, frame)

    local btnContainer = New("Frame", {
        Position = UDim2.new(0.47, 0, 0, 0),
        Size = UDim2.new(0.53, 0, 1, 0),
        BackgroundTransparency = 1,
        ZIndex = 21,
        ClipsDescendants = false,
    }, frame)

    local btn = New("TextButton", {
        BackgroundColor3 = C.Background,
        BorderSizePixel = 0,
        Size = UDim2.new(1, 0, 1, 0),
        Font = Enum.Font.Gotham,
        Text = selected,
        TextColor3 = C.TextPrimary,
        TextSize = 12,
        TextTruncate = Enum.TextTruncate.AtEnd,
        ZIndex = 21,
        AutoButtonColor = false,
    }, btnContainer)
    New("UICorner", { CornerRadius = UDim.new(0, 4) }, btn)
    New("UIPadding", { PaddingLeft = UDim.new(0, 8), PaddingRight = UDim.new(0, 28) }, btn)
    local btnStroke = New("UIStroke", { Color = C.Border, Thickness = 1 }, btn)

    local arrow = New("TextLabel", {
        BackgroundTransparency = 1,
        Position = UDim2.new(1, -22, 0.5, -7),
        Size = UDim2.new(0, 14, 0, 14),
        Text = "▾",
        TextColor3 = C.TextSecondary,
        Font = Enum.Font.GothamBold,
        TextSize = 13,
        ZIndex = 22,
    }, btn)

    -- FIX: listFrame is parented to btnContainer so UDim2 scale=1 = full button width
    local listFrame = New("Frame", {
        BackgroundColor3 = C.Surface,
        BorderSizePixel = 0,
        Position = UDim2.new(0, 0, 0, 34),
        Size = UDim2.new(1, 0, 0, 0),
        ZIndex = 30,
        Visible = false,
        ClipsDescendants = true,
    }, btnContainer)
    New("UICorner", { CornerRadius = UDim.new(0, 6) }, listFrame)
    New("UIStroke", { Color = C.Border, Thickness = 1 }, listFrame)
    New("UIListLayout", { SortOrder = Enum.SortOrder.LayoutOrder, Padding = UDim.new(0, 1) }, listFrame)
    New("UIPadding", { PaddingTop = UDim.new(0, 4), PaddingBottom = UDim.new(0, 4) }, listFrame)

    local optBtns = {}

    local function refreshColors()
        for _, ob in ipairs(optBtns) do
            ob.TextColor3 = (ob.Text == selected) and C.AccentOrange or C.TextSecondary
        end
    end

    local function closeList()
        open = false
        Aether.Tween(listFrame, 0.18, Enum.EasingStyle.Quad, Enum.EasingDirection.Out, { Size = UDim2.new(1, 0, 0, 0) })
        Aether.Tween(arrow, 0.18, nil, nil, { Rotation = 0 })
        Aether.Tween(btnStroke, 0.18, nil, nil, { Color = C.Border })
        task.delay(0.2, function() if listFrame and listFrame.Parent then listFrame.Visible = false end end)
    end

    for _, opt in ipairs(options) do
        local optBtn = New("TextButton", {
            BackgroundColor3 = C.Surface,
            BackgroundTransparency = 1,
            BorderSizePixel = 0,
            Size = UDim2.new(1, -8, 0, 28),
            Position = UDim2.new(0, 4, 0, 0),
            Font = Enum.Font.Gotham,
            Text = opt,
            TextColor3 = (opt == selected) and C.AccentOrange or C.TextSecondary,
            TextSize = 12,
            TextXAlignment = Enum.TextXAlignment.Left,
            ZIndex = 31,
            AutoButtonColor = false,
        }, listFrame)
        New("UIPadding", { PaddingLeft = UDim.new(0, 8) }, optBtn)

        table.insert(optBtns, optBtn)

        optBtn.MouseEnter:Connect(function()
            Aether.Tween(optBtn, 0.12, nil, nil, { BackgroundTransparency = 0.4 })
            if opt ~= selected then optBtn.TextColor3 = C.TextPrimary end
        end)
        optBtn.MouseLeave:Connect(function()
            Aether.Tween(optBtn, 0.12, nil, nil, { BackgroundTransparency = 1 })
            if opt ~= selected then optBtn.TextColor3 = C.TextSecondary end
        end)
        optBtn.MouseButton1Click:Connect(function()
            selected = opt
            btn.Text = opt
            refreshColors()
            closeList()
            pcall(callback, selected)
        end)
    end

    btn.MouseButton1Click:Connect(function()
        open = not open
        if open then
            listFrame.Visible = true
            local height = math.min(#options * 29 + 8, 200)
            Aether.Tween(listFrame, 0.22, Enum.EasingStyle.Quad, Enum.EasingDirection.Out, { Size = UDim2.new(1, 0, 0, height) })
            Aether.Tween(arrow, 0.18, nil, nil, { Rotation = 180 })
            Aether.Tween(btnStroke, 0.18, nil, nil, { Color = C.AccentOrange })
        else
            closeList()
        end
    end)

    return {
        Set = function(_, v)
            selected = v
            btn.Text = v
            refreshColors()
            pcall(callback, selected)
        end,
        Get = function() return selected end,
        Frame = frame,
    }
end

-- ─── Button ──────────────────────────────────────────────────────────────────
function Elements.Button(parent, text, callback, style)
    callback = callback or function() end
    style = style or "primary"

    local baseColor = (style == "danger") and C.Danger
                   or (style == "ghost")  and C.Surface
                   or C.AccentOrange

    local btn = New("TextButton", {
        BackgroundColor3 = baseColor,
        BorderSizePixel = 0,
        Size = UDim2.new(1, 0, 0, 34),
        Font = Enum.Font.GothamBold,
        Text = text,
        TextColor3 = C.TextPrimary,
        TextSize = 13,
        ZIndex = 15,
        AutoButtonColor = false,
    }, parent)
    New("UICorner", { CornerRadius = UDim.new(0, 6) }, btn)

    if style == "primary" then
        local gradient = New("UIGradient", {
            Color = ColorSequence.new({
                ColorSequenceKeypoint.new(0, C.AccentOrange),
                ColorSequenceKeypoint.new(1, C.AccentPurple),
            }),
            Rotation = 45,
        }, btn)
        btn.MouseEnter:Connect(function()
            Aether.Tween(gradient, 0.22, nil, nil, { Rotation = 90 })
        end)
        btn.MouseLeave:Connect(function()
            Aether.Tween(gradient, 0.22, nil, nil, { Rotation = 45 })
        end)
    else
        local stroke = New("UIStroke", {
            Color = (style == "danger") and C.Danger or C.Border,
            Thickness = 1,
        }, btn)
        btn.MouseEnter:Connect(function()
            Aether.Tween(btn, 0.15, nil, nil, { BackgroundColor3 = C.SurfaceHover })
            Aether.Tween(stroke, 0.15, nil, nil, { Color = C.TextSecondary })
        end)
        btn.MouseLeave:Connect(function()
            Aether.Tween(btn, 0.15, nil, nil, { BackgroundColor3 = baseColor })
            Aether.Tween(stroke, 0.15, nil, nil, {
                Color = (style == "danger") and C.Danger or C.Border,
            })
        end)
    end

    btn.MouseButton1Down:Connect(function(x, y)
        Aether.Tween(btn, 0.06, nil, nil, { Size = UDim2.new(1, 0, 0, 31) })
        ripple(btn, x, y)
    end)
    btn.MouseButton1Up:Connect(function()
        Aether.Tween(btn, 0.12, Enum.EasingStyle.Back, Enum.EasingDirection.Out, { Size = UDim2.new(1, 0, 0, 34) })
    end)
    btn.MouseButton1Click:Connect(function() pcall(callback) end)

    return { Frame = btn, SetText = function(_, t) btn.Text = t end }
end

