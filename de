        -- Separator
        function Sec:Separator()
            return New("Frame", {
                BackgroundColor3 = C.Border,
                BorderSizePixel  = 0,
                Size             = UDim2.new(1, 0, 0, 1),
                ZIndex           = 15,
                LayoutOrder      = 999,
            }, content)
        end

        -- Toggle
        function Sec:Toggle(text, default, callback)
            callback = callback or function() end
            local toggled   = default == true
            local animating = false
            local order = #content:GetChildren()

            local frame = New("Frame", {
                BackgroundTransparency = 1,
                Size                   = UDim2.new(1, 0, 0, 32),
                ZIndex                 = 15,
                LayoutOrder            = order,
            }, content)

            local lbl = New("TextLabel", {
                BackgroundTransparency = 1,
                Size                   = UDim2.new(1, -60, 1, 0),
                Font                   = Enum.Font.Gotham,
                Text                   = text,
                TextColor3             = toggled and C.Success or C.TextPrimary,
                TextSize               = 13,
                TextXAlignment         = Enum.TextXAlignment.Left,
                ZIndex                 = 16,
            }, frame)

            local track = New("Frame", {
                BackgroundColor3 = toggled and C.Success or C.Border,
                BorderSizePixel  = 0,
                Position         = UDim2.new(1, -52, 0.5, -10),
                Size             = UDim2.new(0, 44, 0, 20),
                ZIndex           = 16,
            }, frame)
            New("UICorner", { CornerRadius = UDim.new(1, 0) }, track)

            local circle = New("Frame", {
                BackgroundColor3 = Color3.new(1, 1, 1),
                BorderSizePixel  = 0,
                Position         = toggled and UDim2.new(1, -18, 0.5, -8) or UDim2.new(0, 2, 0.5, -8),
                Size             = UDim2.new(0, 16, 0, 16),
                ZIndex           = 17,
            }, track)
            New("UICorner", { CornerRadius = UDim.new(1, 0) }, circle)

            local clickArea = New("TextButton", {
                BackgroundTransparency = 1,
                Size                   = UDim2.new(1, 0, 1, 0),
                Text                   = "",
                ZIndex                 = 18,
                AutoButtonColor        = false,
            }, frame)

            local function setState(v, silent)
                if animating then return end
                animating = true
                toggled   = v
                local dur = 0.18
                if toggled then
                    Tween(track,  dur, Enum.EasingStyle.Sine, nil, { BackgroundColor3 = C.Success })
                    Tween(circle, dur, Enum.EasingStyle.Sine, nil, { Position = UDim2.new(1, -18, 0.5, -8) })
                    Tween(lbl,    dur, nil, nil, { TextColor3 = C.Success })
                else
                    Tween(track,  dur, Enum.EasingStyle.Sine, nil, { BackgroundColor3 = C.Border })
                    Tween(circle, dur, Enum.EasingStyle.Sine, nil, { Position = UDim2.new(0, 2, 0.5, -8) })
                    Tween(lbl,    dur, nil, nil, { TextColor3 = C.TextPrimary })
                end
                task.delay(dur, function() animating = false end)
                if not silent then pcall(callback, toggled) end
            end

            clickArea.MouseButton1Click:Connect(function() setState(not toggled) end)

            return {
                Set   = function(_, v) setState(v, true) end,
                Get   = function() return toggled end,
                Frame = frame,
            }
        end

        -- Slider
        function Sec:Slider(text, min, max, default, callback)
            min, max  = min or 0, max or 100
            default   = math.clamp(default or min, min, max)
            callback  = callback or function() end
            local dragging = false
            local order = #content:GetChildren()

            local frame = New("Frame", {
                BackgroundTransparency = 1,
                Size                   = UDim2.new(1, 0, 0, 50),
                ZIndex                 = 15,
                LayoutOrder            = order,
            }, content)

            New("TextLabel", {
                BackgroundTransparency = 1,
                Size                   = UDim2.new(0.6, 0, 0, 20),
                Font                   = Enum.Font.Gotham,
                Text                   = text,
                TextColor3             = C.TextPrimary,
                TextSize               = 13,
                TextXAlignment         = Enum.TextXAlignment.Left,
                ZIndex                 = 16,
            }, frame)

            local valBox = New("TextBox", {
                BackgroundColor3 = C.Background,
                BorderSizePixel  = 0,
                Position         = UDim2.new(1, -56, 0, 0),
                Size             = UDim2.new(0, 52, 0, 20),
                Font             = Enum.Font.GothamBold,
                Text             = tostring(default),
                TextColor3       = C.TextPrimary,
                TextSize         = 12,
                ClearTextOnFocus = false,
                ZIndex           = 16,
            }, frame)
            New("UICorner", { CornerRadius = UDim.new(0, 4) }, valBox)
            local boxStroke = New("UIStroke", { Color = C.Border, Thickness = 1 }, valBox)

            local track = New("Frame", {
                BackgroundColor3 = C.Border,
                BorderSizePixel  = 0,
                Position         = UDim2.new(0, 0, 0, 34),
                Size             = UDim2.new(1, 0, 0, 5),
                ZIndex           = 16,
            }, frame)
            New("UICorner", { CornerRadius = UDim.new(1, 0) }, track)

            local initScale = (default - min) / (max - min)

            local fill = New("Frame", {
                BackgroundColor3 = C.AccentOrange,
                BorderSizePixel  = 0,
                Size             = UDim2.new(initScale, 0, 1, 0),
                ZIndex           = 17,
            }, track)
            New("UICorner", { CornerRadius = UDim.new(1, 0) }, fill)
            New("UIGradient", {
                Color = ColorSequence.new({
                    ColorSequenceKeypoint.new(0, C.AccentOrange),
                    ColorSequenceKeypoint.new(1, C.AccentPurple),
                }),
            }, fill)

            local thumb = New("Frame", {
                BackgroundColor3 = Color3.new(1, 1, 1),
                BorderSizePixel  = 0,
                Position         = UDim2.new(initScale, -8, 0.5, -8),
                Size             = UDim2.new(0, 16, 0, 16),
                ZIndex           = 18,
            }, track)
            New("UICorner", { CornerRadius = UDim.new(1, 0) }, thumb)
            New("UIStroke", { Color = C.AccentOrange, Thickness = 2 }, thumb)

            local function setSlider(value)
                value = math.clamp(math.floor(value), min, max)
                local sc = (value - min) / (max - min)
                fill.Size         = UDim2.new(sc, 0, 1, 0)
                thumb.Position    = UDim2.new(sc, -8, 0.5, -8)
                valBox.Text       = tostring(value)
                pcall(callback, value)
            end

            local function fromInput(input)
                local sc = math.clamp(
                    (input.Position.X - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1
                )
                setSlider(sc * (max - min) + min)
            end

            thumb.InputBegan:Connect(function(i)
                if i.UserInputType == Enum.UserInputType.MouseButton1 then dragging = true end
            end)
            track.InputBegan:Connect(function(i)
                if i.UserInputType == Enum.UserInputType.MouseButton1 then fromInput(i) end
            end)
            UserInputService.InputEnded:Connect(function(i)
                if i.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
            end)
            UserInputService.InputChanged:Connect(function(i)
                if dragging and i.UserInputType == Enum.UserInputType.MouseMovement then fromInput(i) end
            end)

            valBox.Focused:Connect(function()
                Tween(boxStroke, 0.15, nil, nil, { Color = C.AccentOrange })
            end)
            valBox.FocusLost:Connect(function()
                Tween(boxStroke, 0.15, nil, nil, { Color = C.Border })
                local v = tonumber(valBox.Text)
                if v then setSlider(v) end
            end)

            return {
                Set   = function(_, v) setSlider(v) end,
                Get   = function() return tonumber(valBox.Text) or default end,
                Frame = frame,
            }
        end

        -- Dropdown
        function Sec:Dropdown(text, options, default, callback)
            options  = options or {}
            default  = default or 1
            callback = callback or function() end
            local selected = options[default] or options[1] or "None"
            local open     = false
            local order    = #content:GetChildren()

            local frame = New("Frame", {
                BackgroundTransparency = 1,
                Size                   = UDim2.new(1, 0, 0, 32),
                ZIndex                 = 20,
                ClipsDescendants       = false,
                LayoutOrder            = order,
            }, content)

            New("TextLabel", {
                BackgroundTransparency = 1,
                Size                   = UDim2.new(0.45, 0, 1, 0),
                Font                   = Enum.Font.Gotham,
                Text                   = text,
                TextColor3             = C.TextPrimary,
                TextSize               = 13,
                TextXAlignment         = Enum.TextXAlignment.Left,
                ZIndex                 = 21,
            }, frame)

            local btn = New("TextButton", {
                BackgroundColor3 = C.Background,
                BorderSizePixel  = 0,
                Position         = UDim2.new(0.47, 0, 0, 0),
                Size             = UDim2.new(0.53, 0, 1, 0),
                Font             = Enum.Font.Gotham,
                Text             = selected,
                TextColor3       = C.TextPrimary,
                TextSize         = 12,
                TextTruncate     = Enum.TextTruncate.AtEnd,
                ZIndex           = 21,
                AutoButtonColor  = false,
            }, frame)
            New("UICorner", { CornerRadius = UDim.new(0, 5) }, btn)
            local btnStroke = New("UIStroke", { Color = C.Border, Thickness = 1 }, btn)
            New("UIPadding", { PaddingLeft = UDim.new(0, 8), PaddingRight = UDim.new(0, 22) }, btn)

            -- Chevron icon (text-based)
            local chevron = New("TextLabel", {
                BackgroundTransparency = 1,
                Position               = UDim2.new(1, -20, 0.5, -7),
                Size                   = UDim2.new(0, 14, 0, 14),
                Font                   = Enum.Font.GothamBold,
                Text                   = "▾",
                TextColor3             = C.TextSecondary,
                TextSize               = 12,
                ZIndex                 = 22,
            }, btn)

            local listFrame = New("Frame", {
                BackgroundColor3 = C.SurfaceHover,
                BorderSizePixel  = 0,
                Position         = UDim2.new(0.47, 0, 0, 34),
                Size             = UDim2.new(0.53, 0, 0, 0),
                ZIndex           = 30,
                Visible          = false,
                ClipsDescendants = true,
            }, frame)
            New("UICorner", { CornerRadius = UDim.new(0, 7) }, listFrame)
            New("UIStroke", { Color = C.Border, Thickness = 1 }, listFrame)
            New("UIListLayout", { SortOrder = Enum.SortOrder.LayoutOrder, Padding = UDim.new(0, 1) }, listFrame)
            New("UIPadding", { PaddingTop = UDim.new(0, 4), PaddingBottom = UDim.new(0, 4), PaddingLeft = UDim.new(0, 4), PaddingRight = UDim.new(0, 4) }, listFrame)

            for _, opt in ipairs(options) do
                local optBtn = New("TextButton", {
                    BackgroundColor3     = C.SurfaceHover,
                    BackgroundTransparency = 1,
                    BorderSizePixel      = 0,
                    Size                 = UDim2.new(1, 0, 0, 28),
                    Font                 = Enum.Font.Gotham,
                    Text                 = opt,
                    TextColor3           = (opt == selected) and C.AccentOrange or C.TextSecondary,
                    TextSize             = 12,
                    TextXAlignment       = Enum.TextXAlignment.Left,
                    ZIndex               = 31,
                    AutoButtonColor      = false,
                }, listFrame)
                New("UICorner", { CornerRadius = UDim.new(0, 4) }, optBtn)
                New("UIPadding", { PaddingLeft = UDim.new(0, 8) }, optBtn)

                optBtn.MouseEnter:Connect(function()
                    Tween(optBtn, 0.12, nil, nil, { BackgroundTransparency = 0.6, TextColor3 = C.TextPrimary })
                end)
                optBtn.MouseLeave:Connect(function()
                    Tween(optBtn, 0.12, nil, nil, {
                        BackgroundTransparency = 1,
                        TextColor3 = (opt == selected) and C.AccentOrange or C.TextSecondary
                    })
                end)
                optBtn.MouseButton1Click:Connect(function()
                    selected  = opt
                    btn.Text  = selected
                    open      = false
                    Tween(listFrame, 0.18, nil, nil, { Size = UDim2.new(0.53, 0, 0, 0) })
                    Tween(chevron, 0.18, nil, nil, { Rotation = 0 })
                    Tween(btnStroke, 0.18, nil, nil, { Color = C.Border })
                    task.delay(0.2, function() listFrame.Visible = false end)
                    for _, child in ipairs(listFrame:GetChildren()) do
                        if child:IsA("TextButton") then
                            child.TextColor3 = (child.Text == selected) and C.AccentOrange or C.TextSecondary
                        end
                    end
                    pcall(callback, selected)
                end)
            end

            btn.MouseButton1Click:Connect(function()
                open = not open
                if open then
                    listFrame.Visible = true
                    local h = math.min(#options * 29 + 8, 200)
                    Tween(listFrame, 0.22, Enum.EasingStyle.Quad, nil, { Size = UDim2.new(0.53, 0, 0, h) })
                    Tween(chevron, 0.18, nil, nil, { Rotation = 180 })
                    Tween(btnStroke, 0.18, nil, nil, { Color = C.AccentOrange })
                else
                    Tween(listFrame, 0.18, nil, nil, { Size = UDim2.new(0.53, 0, 0, 0) })
                    Tween(chevron, 0.18, nil, nil, { Rotation = 0 })
                    Tween(btnStroke, 0.18, nil, nil, { Color = C.Border })
                    task.delay(0.2, function() listFrame.Visible = false end)
                end
            end)

            return {
                Set   = function(_, v) selected = v; btn.Text = selected; pcall(callback, selected) end,
                Get   = function() return selected end,
                Frame = frame,
            }
        end

        -- Button
        function Sec:Button(text, callback, style)
            callback = callback or function() end
            style    = style or "primary"
            local order = #content:GetChildren()

            local bgColor = style == "danger"    and C.Danger
                         or style == "secondary" and C.Surface
                         or C.AccentOrange

            local btn = New("TextButton", {
                BackgroundColor3 = bgColor,
                BorderSizePixel  = 0,
                Size             = UDim2.new(1, 0, 0, 34),
                Font             = Enum.Font.GothamBold,
                Text             = text,
                TextColor3       = C.TextPrimary,
                TextSize         = 13,
                ZIndex           = 15,
                AutoButtonColor  = false,
                LayoutOrder      = order,
                ClipsDescendants = true,
            }, content)
            New("UICorner", { CornerRadius = UDim.new(0, 6) }, btn)

            if style == "primary" then
                New("UIGradient", {
                    Color = ColorSequence.new({
                        ColorSequenceKeypoint.new(0, C.AccentOrange),
                        ColorSequenceKeypoint.new(1, C.AccentPurple),
                    }),
                    Rotation = 35,
                }, btn)
                btn.MouseEnter:Connect(function()
                    Tween(btn, 0.18, nil, nil, { BackgroundColor3 = C.AccentPurple })
                end)
                btn.MouseLeave:Connect(function()
                    Tween(btn, 0.18, nil, nil, { BackgroundColor3 = C.AccentOrange })
                end)
            else
                local stroke = New("UIStroke", {
                    Color     = style == "danger" and C.Danger or C.Border,
                    Thickness = 1,
                }, btn)
                btn.MouseEnter:Connect(function()
                    Tween(btn, 0.18, nil, nil, { BackgroundColor3 = C.SurfaceHover })
                    Tween(stroke, 0.18, nil, nil, { Color = C.TextSecondary })
                end)
                btn.MouseLeave:Connect(function()
                    Tween(btn, 0.18, nil, nil, { BackgroundColor3 = bgColor })
                    Tween(stroke, 0.18, nil, nil, { Color = style == "danger" and C.Danger or C.Border })
                end)
            end

            btn.MouseButton1Down:Connect(function(mx, my)
                Tween(btn, 0.07, nil, nil, { Size = UDim2.new(1, 0, 0, 31) })
                Ripple(btn, mx, my)
            end)
            btn.MouseButton1Up:Connect(function()
                Tween(btn, 0.12, Enum.EasingStyle.Back, Enum.EasingDirection.Out, { Size = UDim2.new(1, 0, 0, 34) })
            end)
            btn.MouseButton1Click:Connect(function() pcall(callback) end)

            return { Frame = btn }
        end

        -- TextBox
        function Sec:TextBox(text, placeholder, callback)
            callback = callback or function() end
            local order = #content:GetChildren()

            local frame = New("Frame", {
                BackgroundTransparency = 1,
                Size                   = UDim2.new(1, 0, 0, 32),
                ZIndex                 = 15,
                LayoutOrder            = order,
            }, content)

            New("TextLabel", {
                BackgroundTransparency = 1,
                Size                   = UDim2.new(0.4, 0, 1, 0),
                Font                   = Enum.Font.Gotham,
                Text                   = text,
                TextColor3             = C.TextPrimary,
                TextSize               = 13,
                TextXAlignment         = Enum.TextXAlignment.Left,
                ZIndex                 = 16,
            }, frame)

            local box = New("TextBox", {
                BackgroundColor3 = C.Background,
                BorderSizePixel  = 0,
                Position         = UDim2.new(0.42, 0, 0, 0),
                Size             = UDim2.new(0.58, 0, 1, 0),
                Font             = Enum.Font.Gotham,
                Text             = "",
                PlaceholderText  = placeholder or "...",
                PlaceholderColor3 = C.TextMuted,
                TextColor3       = C.TextPrimary,
                TextSize         = 12,
                ClearTextOnFocus = false,
                ZIndex           = 16,
            }, frame)
            New("UICorner", { CornerRadius = UDim.new(0, 4) }, box)
            local stroke = New("UIStroke", { Color = C.Border, Thickness = 1 }, box)
            New("UIPadding", { PaddingLeft = UDim.new(0, 6) }, box)

            box.Focused:Connect(function()
                Tween(stroke, 0.15, nil, nil, { Color = C.AccentOrange })
            end)
            box.FocusLost:Connect(function()
                Tween(stroke, 0.15, nil, nil, { Color = C.Border })
                pcall(callback, box.Text)
            end)

            return {
                Set   = function(_, v) box.Text = v end,
                Get   = function() return box.Text end,
                Frame = frame,
            }
        end

        -- KeyPicker
        function Sec:KeyPicker(text, defaultKey, callback)
            callback = callback or function() end
            local keyName  = defaultKey and defaultKey.Name or "None"
            local listening = false
            local order = #content:GetChildren()
            local conn

            local frame = New("Frame", {
                BackgroundTransparency = 1,
                Size                   = UDim2.new(1, 0, 0, 32),
                ZIndex                 = 15,
                LayoutOrder            = order,
            }, content)

            New("TextLabel", {
                BackgroundTransparency = 1,
                Size                   = UDim2.new(0.55, 0, 1, 0),
                Font                   = Enum.Font.Gotham,
                Text                   = text,
                TextColor3             = C.TextPrimary,
                TextSize               = 13,
                TextXAlignment         = Enum.TextXAlignment.Left,
                ZIndex                 = 16,
            }, frame)

            local keyBtn = New("TextButton", {
                BackgroundColor3 = C.Background,
                BorderSizePixel  = 0,
                Position         = UDim2.new(0.58, 0, 0, 0),
                Size             = UDim2.new(0.42, 0, 1, 0),
                Font             = Enum.Font.GothamBold,
                Text             = keyName,
                TextColor3       = C.AccentOrange,
                TextSize         = 12,
                ZIndex           = 16,
                AutoButtonColor  = false,
            }, frame)
            New("UICorner", { CornerRadius = UDim.new(0, 4) }, keyBtn)
            local stroke = New("UIStroke", { Color = C.Border, Thickness = 1 }, keyBtn)

            keyBtn.MouseEnter:Connect(function()
                if not listening then Tween(stroke, 0.15, nil, nil, { Color = C.AccentOrange }) end
            end)
            keyBtn.MouseLeave:Connect(function()
                if not listening then Tween(stroke, 0.15, nil, nil, { Color = C.Border }) end
            end)

            keyBtn.MouseButton1Click:Connect(function()
                if listening then return end
                listening = true
                keyBtn.Text = "[ ... ]"
                keyBtn.TextColor3 = C.Warning
                Tween(stroke, 0.15, nil, nil, { Color = C.Warning })

                conn = UserInputService.InputBegan:Connect(function(input, gpe)
                    if gpe then return end
                    if input.UserInputType == Enum.UserInputType.Keyboard then
                        keyName = input.KeyCode.Name
                        keyBtn.Text = keyName
                        keyBtn.TextColor3 = C.AccentOrange
                        Tween(stroke, 0.15, nil, nil, { Color = C.Border })
                        listening = false
                        if conn then conn:Disconnect(); conn = nil end
                    end
                end)
            end)

            -- Hotkey listener
            UserInputService.InputBegan:Connect(function(input, gpe)
                if gpe then return end
                if not listening and input.KeyCode.Name == keyName then
                    pcall(callback)
                end
            end)

            return {
                Get   = function() return keyName end,
                Frame = frame,
            }
        end

        return Sec
    end -- Tab:Section

    return Tab
end -- Aether:Tab

