-- FIX: Smoother visualizer — sine-based per-bar offset instead of math.random per frame
function MusicPlayer:_startVisualizer()
    local t = 0
    local conn = RunService.Heartbeat:Connect(function(dt)
        t = t + dt
        if not (self._sound and self._isPlaying) then
            for _, bar in ipairs(self._visualizerBars) do
                if bar and bar.Parent then
                    local idleH = 2 + math.sin(t * 1.5 + self._barPhases[_]) * 1.5
                    Aether.Tween(bar, 0.15, nil, nil, { Size = UDim2.new(0, 5, 0, idleH) })
                end
            end
            return
        end
        local loudness = self._sound.PlaybackLoudness or 0
        for i, bar in ipairs(self._visualizerBars) do
            if bar and bar.Parent then
                local phase  = self._barPhases[i]
                local modAmt = 0.65 + 0.35 * math.sin(t * 4 + phase)
                local h      = math.clamp((loudness / 420) * modAmt * 140 + 3, 2, 145)
                Aether.Tween(bar, 0.06, Enum.EasingStyle.Linear, nil, { Size = UDim2.new(0, 5, 0, h) })
            end
        end
    end)
    table.insert(self._connections, conn)
end

function MusicPlayer:AddTrack(name, artist, soundId)
    table.insert(self._playlist, { Name = name, Artist = artist, SoundId = soundId })
    local index = #self._playlist

    local btn = New("TextButton", {
        BackgroundColor3 = C.Surface,
