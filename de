function Elements.ColorPicker(parent, text, default, callback)
    default  = default  or Color3.fromRGB(255, 115, 55)
    callback = callback or function() end
    local color = default
    local open = false

    local frame = New("Frame", {
        Name = text .. "ColorPicker",
        BackgroundTransparency = 1,
        Size = UDim2.new(1, 0, 0, 32),
        ZIndex = 20,
        ClipsDescendants = false,
    }, parent)

    New("TextLabel", {
        BackgroundTransparency = 1,
        Size = UDim2.new(0.60, 0, 1, 0),
        Font = Enum.Font.Gotham,
        Text = text,
        TextColor3 = C.TextPrimary,
        TextSize = 13,
        TextXAlignment = Enum.TextXAlignment.Left,
        ZIndex = 21,
    }, frame)

    local preview = New("TextButton", {
        Position = UDim2.new(0.63, 0, 0.5, -10),
        Size = UDim2.new(0.37, 0, 0, 20),
        BackgroundColor3 = color,
        BorderSizePixel = 0,
        Text = "",
        ZIndex = 21,
        AutoButtonColor = false,
    }, frame)
    New("UICorner", { CornerRadius = UDim.new(0, 4) }, preview)
    local previewStroke = New("UIStroke", { Color = C.Border, Thickness = 1 }, preview)

    -- Simple H+S picker panel
    local panel = New("Frame", {
        BackgroundColor3 = C.Surface,
        BorderSizePixel = 0,
        Position = UDim2.new(0.63, 0, 0, 34),
        Size = UDim2.new(0.37, 0, 0, 0),
        ZIndex = 35,
        Visible = false,
        ClipsDescendants = true,
    }, frame)
    New("UICorner", { CornerRadius = UDim.new(0, 6) }, panel)
    New("UIStroke", { Color = C.Border, Thickness = 1 }, panel)

    local panelPad = New("Frame", {
        BackgroundTransparency = 1,
        Size = UDim2.new(1, 0, 1, 0),
        ZIndex = 36,
    }, panel)
    New("UIPadding", {
        PaddingLeft = UDim.new(0, 8), PaddingRight = UDim.new(0, 8),
        PaddingTop = UDim.new(0, 8), PaddingBottom = UDim.new(0, 8),
    }, panelPad)
    New("UIListLayout", { Padding = UDim.new(0, 6) }, panelPad)

    -- Hue, Saturation, Value sliders
    local function makeSlider(lbl, col)
        local sf = New("Frame", { BackgroundTransparency = 1, Size = UDim2.new(1, 0, 0, 18), ZIndex = 36 }, panelPad)
        New("TextLabel", { BackgroundTransparency = 1, Size = UDim2.new(0.25, 0, 1, 0),
            Font = Enum.Font.Gotham, Text = lbl, TextColor3 = C.TextMuted, TextSize = 9,
            TextXAlignment = Enum.TextXAlignment.Left, ZIndex = 37 }, sf)
        local tr = New("Frame", { BackgroundColor3 = col, BorderSizePixel = 0,
            Position = UDim2.new(0.28, 0, 0.5, -3), Size = UDim2.new(0.72, 0, 0, 6), ZIndex = 37 }, sf)
        New("UICorner", { CornerRadius = UDim.new(1, 0) }, tr)
        local th = New("Frame", { BackgroundColor3 = C.TextPrimary, BorderSizePixel = 0,
            Position = UDim2.new(0, -5, 0.5, -5), Size = UDim2.new(0, 10, 0, 10), ZIndex = 38 }, tr)
        New("UICorner", { CornerRadius = UDim.new(1, 0) }, th)
        return tr, th
    end

    local hueTrack,   hueThumb   = makeSlider("H", Color3.fromRGB(200, 50, 50))
    local satTrack,   satThumb   = makeSlider("S", Color3.fromRGB(150, 150, 200))
    local valTrack,   valThumb   = makeSlider("V", Color3.fromRGB(180, 180, 180))

    local h, s, v = Color3.toHSV(color)
    local draggingTrack = nil

    local function applyHSV()
        color = Color3.fromHSV(h, s, v)
        preview.BackgroundColor3 = color
        hueThumb.Position  = UDim2.new(h, -5, 0.5, -5)
        satThumb.Position  = UDim2.new(s, -5, 0.5, -5)
        valThumb.Position  = UDim2.new(v, -5, 0.5, -5)
        pcall(callback, color)
    end

    local function dragTrack(track, input)
        local pct = math.clamp((input.Position.X - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
        if track == hueTrack then h = pct
        elseif track == satTrack then s = pct
        elseif track == valTrack then v = pct end
        applyHSV()
    end

    for _, pair in ipairs({ {hueTrack, hueThumb}, {satTrack, satThumb}, {valTrack, valThumb} }) do
        local tr, th = pair[1], pair[2]
        th.InputBegan:Connect(function(inp)
            if inp.UserInputType == Enum.UserInputType.MouseButton1 then draggingTrack = tr end
        end)
        tr.InputBegan:Connect(function(inp)
            if inp.UserInputType == Enum.UserInputType.MouseButton1 then
                draggingTrack = tr
                dragTrack(tr, inp)
            end
        end)
    end
    UserInputService.InputEnded:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 then draggingTrack = nil end
    end)
    UserInputService.InputChanged:Connect(function(inp)
        if draggingTrack and inp.UserInputType == Enum.UserInputType.MouseMovement then
            dragTrack(draggingTrack, inp)
        end
    end)

    applyHSV()

    preview.MouseButton1Click:Connect(function()
        open = not open
        if open then
            panel.Visible = true
            Aether.Tween(panel, 0.2, nil, nil, { Size = UDim2.new(0.37, 0, 0, 100) })
            Aether.Tween(previewStroke, 0.15, nil, nil, { Color = C.AccentOrange })
        else
            Aether.Tween(panel, 0.18, nil, nil, { Size = UDim2.new(0.37, 0, 0, 0) })
            Aether.Tween(previewStroke, 0.15, nil, nil, { Color = C.Border })
            task.delay(0.2, function() if panel and panel.Parent then panel.Visible = false end end)
        end
    end)

    return {
        Get = function() return color end,
        Set = function(_, c)
            color = c
            h, s, v = Color3.toHSV(c)
            applyHSV()
        end,
        Frame = frame,
    }
end

