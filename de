        Font = Enum.Font.Gotham,
        Text = "  " .. name .. "  —  " .. artist,
        TextColor3 = C.TextSecondary,
        TextSize = 11,
        TextXAlignment = Enum.TextXAlignment.Left,
        ZIndex = 17,
        AutoButtonColor = false,
    }, self._playlistFrame)
    New("UIPadding", { PaddingLeft = UDim.new(0, 6) }, btn)

    btn.MouseEnter:Connect(function()
        Aether.Tween(btn, 0.12, nil, nil, { BackgroundTransparency = 0.4 })
        btn.TextColor3 = C.TextPrimary
    end)
    btn.MouseLeave:Connect(function()
        Aether.Tween(btn, 0.12, nil, nil, { BackgroundTransparency = 1 })
        btn.TextColor3 = C.TextSecondary
    end)
    btn.MouseButton1Click:Connect(function() self:LoadTrack(index) end)

    self._playlistFrame.CanvasSize = UDim2.new(0, 0, 0, #self._playlist * 27)
end

function MusicPlayer:LoadTrack(index)
    self._currentTrack = index
    local track = self._playlist[index]
    if not track then return end

    self._trackTitle.Text  = track.Name
    self._trackArtist.Text = track.Artist

    if self._sound then
        self._sound:Stop()
        self._sound:Destroy()
        self._sound = nil
    end

    local snd = Instance.new("Sound")
    snd.Parent  = SoundService
    snd.SoundId = track.SoundId
    snd.Volume  = 0.5
    self._sound = snd

    snd.Ended:Connect(function() self:Next() end)

    task.spawn(function()
        while snd and snd.Parent do
            if snd.IsPlaying then
                local cur   = math.floor(snd.TimePosition)
                local total = math.floor(snd.TimeLength)
                if total > 0 then
                    self._progressFill.Size = UDim2.new(cur / total, 0, 1, 0)
                    self._timeLabel.Text = string.format("%d:%02d / %d:%02d",
                        math.floor(cur / 60), cur % 60,
                        math.floor(total / 60), total % 60)
                end
            end
            task.wait(0.1)
        end
    end)

    self:Play()
end

function MusicPlayer:Play()
    if self._sound then
        self._sound:Play()
        self._isPlaying = true
        self._playBtn.Text = "⏸"
    end
end

function MusicPlayer:Pause()
    if self._sound then
        self._sound:Pause()
        self._isPlaying = false
        self._playBtn.Text = "▶"
    end
end

function MusicPlayer:Stop()
    if self._sound then
        self._sound:Stop()
        self._isPlaying = false
        self._playBtn.Text = "▶"
        self._progressFill.Size = UDim2.new(0, 0, 1, 0)
        self._timeLabel.Text = "0:00 / 0:00"
    end
end

function MusicPlayer:TogglePlay()
    if self._isPlaying then self:Pause() else self:Play() end
end

function MusicPlayer:Next()
    if #self._playlist == 0 then return end
    local nxt = self._currentTrack % #self._playlist + 1
    self:LoadTrack(nxt)
end

function MusicPlayer:Previous()
    if #self._playlist == 0 then return end
    local prv = ((self._currentTrack - 2) % #self._playlist) + 1
    self:LoadTrack(prv)
end

function MusicPlayer:Destroy()
    for _, conn in ipairs(self._connections) do pcall(function() conn:Disconnect() end) end
    if self._sound then self._sound:Destroy() end
    if self._frame then self._frame:Destroy() end
end

