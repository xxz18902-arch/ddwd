-- FIX: guard against key == "None" firing; listener properly disconnects
function Elements.KeyPicker(parent, text, defaultKey, callback)
    callback = callback or function() end
    local key = (defaultKey and defaultKey.Name) or "None"
    local listening = false
    local keyConn = nil

    local frame = New("Frame", {
        BackgroundTransparency = 1,
        Size = UDim2.new(1, 0, 0, 32),
        ZIndex = 15,
    }, parent)

    New("TextLabel", {
        BackgroundTransparency = 1,
        Size = UDim2.new(0.55, 0, 1, 0),
        Font = Enum.Font.Gotham,
        Text = text,
        TextColor3 = C.TextPrimary,
        TextSize = 13,
        TextXAlignment = Enum.TextXAlignment.Left,
        ZIndex = 16,
    }, frame)

    local keyBtn = New("TextButton", {
        BackgroundColor3 = C.Background,
        BorderSizePixel = 0,
        Position = UDim2.new(0.58, 0, 0, 0),
        Size = UDim2.new(0.42, 0, 1, 0),
        Font = Enum.Font.GothamBold,
        Text = key,
        TextColor3 = C.AccentOrange,
        TextSize = 12,
        ZIndex = 16,
        AutoButtonColor = false,
    }, frame)
    New("UICorner", { CornerRadius = UDim.new(0, 4) }, keyBtn)
    local stroke = New("UIStroke", { Color = C.Border, Thickness = 1 }, keyBtn)

    keyBtn.MouseEnter:Connect(function()
        if not listening then Aether.Tween(stroke, 0.15, nil, nil, { Color = C.AccentOrange }) end
    end)
    keyBtn.MouseLeave:Connect(function()
        if not listening then Aether.Tween(stroke, 0.15, nil, nil, { Color = C.Border }) end
    end)

    keyBtn.MouseButton1Click:Connect(function()
        if listening then return end
        listening = true
        keyBtn.Text = "[ press key ]"
        keyBtn.TextColor3 = C.Warning
        Aether.Tween(stroke, 0.15, nil, nil, { Color = C.Warning })

        if keyConn then keyConn:Disconnect(); keyConn = nil end

        keyConn = UserInputService.InputBegan:Connect(function(input, gpe)
            if gpe then return end
            if input.UserInputType == Enum.UserInputType.Keyboard then
                key = input.KeyCode.Name
                keyBtn.Text = key
                keyBtn.TextColor3 = C.AccentOrange
                Aether.Tween(stroke, 0.15, nil, nil, { Color = C.Border })
                listening = false
                if keyConn then keyConn:Disconnect(); keyConn = nil end
            end
        end)
    end)

    -- FIX: only fire if key is not "None" and not currently listening
    UserInputService.InputBegan:Connect(function(input, gpe)
        if gpe then return end
        if listening then return end
        if key == "None" then return end
        if input.UserInputType == Enum.UserInputType.Keyboard and input.KeyCode.Name == key then
            pcall(callback)
        end
    end)

    return {
        Get = function() return key end,
        Set = function(_, k) key = k; keyBtn.Text = k end,
        Frame = frame,
    }
end

