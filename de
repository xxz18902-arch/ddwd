-- FIX: dir detection was inverted — listfiles() succeeds on dirs and fails on files
function FileBrowser:Refresh(path)
    self._currentPath = path or ""
    self._pathText.Text = (#self._currentPath > 0 and self._currentPath or "workspace/")

    for _, child in ipairs(self._fileList:GetChildren()) do
        if child:IsA("TextButton") then child:Destroy() end
    end

    if #self._currentPath > 0 then
        local parentPath = self._currentPath:match("^(.*)[/\\]") or ""
        self:_addEntry("..", true, parentPath)
    end

    if listfiles then
        local success, files = pcall(listfiles, self._currentPath)
        if success and files then
            table.sort(files)
            local entryCount = 1
            for _, file in ipairs(files) do
                local name = file:match("([^/\\]+)$") or file
                -- FIX: isDir = listfiles succeeds on it (it's a directory)
                local isDir = pcall(listfiles, file)
                self:_addEntry(name, isDir, file)
                entryCount = entryCount + 1
            end
            self._fileList.CanvasSize = UDim2.new(0, 0, 0, entryCount * 29 + 8)
        else
            New("TextLabel", {
                BackgroundTransparency = 1,
                Size = UDim2.new(1, 0, 0, 40),
                Font = Enum.Font.Gotham,
                Text = "Could not read directory.",
                TextColor3 = C.Danger,
                TextSize = 11,
                ZIndex = 17,
            }, self._fileList)
        end
    else
        New("TextLabel", {
            BackgroundTransparency = 1,
            Size = UDim2.new(1, 0, 0, 60),
            Font = Enum.Font.Gotham,
            Text = "listfiles() unavailable.\nRequires Synapse X, KRNL, or Fluxus.",
            TextColor3 = C.TextMuted,
            TextSize = 11,
            TextWrapped = true,
            ZIndex = 17,
        }, self._fileList)
    end
end

function FileBrowser:OnSelect(fn) self._onSelect = fn end

function FileBrowser:Destroy()
    if self._frame then self._frame:Destroy() end
end

