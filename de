        BackgroundColor3 = C.Surface,
        BackgroundTransparency = 1,
        Text = "",
        BorderSizePixel = 0,
        LayoutOrder = pageCount,
        ZIndex = 7,
        AutoButtonColor = false,
    }, self._navList)

    local indicator = New("Frame", {
        Name = "Indicator",
        Size = UDim2.new(0, 3, 0, 0),
        Position = UDim2.new(0, 0, 0.5, 0),
        AnchorPoint = Vector2.new(0, 0.5),
        BackgroundColor3 = C.AccentOrange,
        BorderSizePixel = 0,
        ZIndex = 8,
    }, btn)
    New("UICorner", { CornerRadius = UDim.new(0, 2) }, indicator)

    New("TextLabel", {
        Name = "Icon",
        Position = UDim2.new(0, 16, 0, 0),
        Size = UDim2.new(0, 20, 1, 0),
        BackgroundTransparency = 1,
        Text = icon or "◈",
        TextColor3 = C.TextSecondary,
        Font = Enum.Font.GothamBold,
        TextSize = 14,
        ZIndex = 8,
    }, btn)

    local label = New("TextLabel", {
        Name = "Label",
        Position = UDim2.new(0, 44, 0, 0),
        Size = UDim2.new(1, -44, 1, 0),
        BackgroundTransparency = 1,
        Text = name,
        TextColor3 = C.TextSecondary,
        Font = Enum.Font.Gotham,
        TextSize = 13,
        TextXAlignment = Enum.TextXAlignment.Left,
        ZIndex = 8,
    }, btn)

    local page = New("ScrollingFrame", {
        Name = "Page_" .. name,
        Size = UDim2.fromScale(1, 1),
        BackgroundTransparency = 1,
        BorderSizePixel = 0,
        ScrollBarThickness = 4,
        ScrollBarImageColor3 = C.BorderLight,
        CanvasSize = UDim2.new(0, 0, 0, 0),
        AutomaticCanvasSize = Enum.AutomaticSize.Y,
        Visible = false,
        ZIndex = 6,
    }, self._pagesFrame)
    New("UIPadding", {
        PaddingTop    = UDim.new(0, 14),
        PaddingLeft   = UDim.new(0, 16),
        PaddingRight  = UDim.new(0, 16),
        PaddingBottom = UDim.new(0, 14),
    }, page)
    New("UIListLayout", {
        SortOrder = Enum.SortOrder.LayoutOrder,
        Padding   = UDim.new(0, 10),
    }, page)

    local pageData = { name = name, frame = page, btn = btn, indicator = indicator, label = label }
    table.insert(self._pages, pageData)

    btn.MouseEnter:Connect(function()
        if self._activePage ~= pageData then
            Aether.TweenHover(btn,   { BackgroundTransparency = 0.6 })
            Aether.TweenHover(label, { TextColor3 = C.TextPrimary })
        end
    end)
    btn.MouseLeave:Connect(function()
        if self._activePage ~= pageData then
            Aether.TweenHover(btn,   { BackgroundTransparency = 1 })
            Aether.TweenHover(label, { TextColor3 = C.TextSecondary })
        end
    end)
    btn.MouseButton1Click:Connect(function() self:SelectPage(pageData) end)

    if pageCount == 1 then self:SelectPage(pageData) end

    -- Convenience: add a section directly from the page object
    function page:AddSection(title) return Elements.Section(page, title) end

    return page
end

function Aether:SelectPage(pageData)
    if self._activePage then
        local prev = self._activePage
        prev.frame.Visible = false
        Aether.TweenHover(prev.btn,       { BackgroundTransparency = 1 })
        Aether.TweenHover(prev.label,     { TextColor3 = C.TextSecondary })
        Aether.TweenHover(prev.indicator, { Size = UDim2.new(0, 3, 0, 0) })
        local prevIcon = prev.btn:FindFirstChild("Icon")
        if prevIcon then Aether.TweenHover(prevIcon, { TextColor3 = C.TextSecondary }) end
    end

    self._activePage = pageData
    pageData.frame.Visible = true
    Aether.TweenHover(pageData.btn,       { BackgroundTransparency = 0.3 })
    Aether.TweenHover(pageData.label,     { TextColor3 = C.TextPrimary })
    Aether.TweenHover(pageData.indicator, { Size = UDim2.new(0, 3, 1, 0) })
    local icon = pageData.btn:FindFirstChild("Icon")
    if icon then Aether.TweenHover(icon, { TextColor3 = C.AccentOrange }) end

    self:SetStatus("Tab: " .. pageData.name, C.TextSecondary)
end

-- ─── Notifications (NEW) ─────────────────────────────────────────────────────
-- UI:Notify("Title", "Message", "success"|"warning"|"error"|"info", duration)
function Aether:Notify(title, message, notifType, duration)
    duration = duration or 3.5
    notifType = notifType or "info"

    local color = (notifType == "success") and C.Success
               or (notifType == "warning") and C.Warning
               or (notifType == "error")   and C.Danger
               or C.AccentBlue

    local icon = (notifType == "success") and "✓"
              or (notifType == "warning") and "⚠"
              or (notifType == "error")   and "✕"
              or "ℹ"

    -- Container positioned bottom-right of root
    if not self._notifHolder then
        self._notifHolder = New("Frame", {
            AnchorPoint = Vector2.new(1, 1),
            Position = UDim2.new(1, -16, 1, -16),
            Size = UDim2.new(0, 280, 1, -32),
            BackgroundTransparency = 1,
            ZIndex = 50,
        }, self._root)
        New("UIListLayout", {
            SortOrder = Enum.SortOrder.LayoutOrder,
            VerticalAlignment = Enum.VerticalAlignment.Bottom,
            Padding = UDim.new(0, 8),
        }, self._notifHolder)
    end

    local card = New("Frame", {
        BackgroundColor3 = C.Surface,
        BorderSizePixel = 0,
        Size = UDim2.new(1, 0, 0, 64),
        ZIndex = 51,
        BackgroundTransparency = 0,
    }, self._notifHolder)
    New("UICorner", { CornerRadius = UDim.new(0, 8) }, card)
    New("UIStroke", { Color = C.Border, Thickness = 1 }, card)

    -- Accent left bar
    local accent = New("Frame", {
        BackgroundColor3 = color,
        BorderSizePixel = 0,
        Size = UDim2.new(0, 3, 1, 0),
        ZIndex = 52,
    }, card)
    New("UICorner", { CornerRadius = UDim.new(0, 8) }, accent)

    New("TextLabel", {
        Position = UDim2.new(0, 18, 0, 10),
        Size = UDim2.new(0, 20, 0, 20),
        BackgroundTransparency = 1,
        Text = icon,
        TextColor3 = color,
        Font = Enum.Font.GothamBold,
        TextSize = 14,
        ZIndex = 52,
    }, card)

    New("TextLabel", {
        Position = UDim2.new(0, 44, 0, 8),
        Size = UDim2.new(1, -52, 0, 20),
        BackgroundTransparency = 1,
        Text = title,
        TextColor3 = C.TextPrimary,
        Font = Enum.Font.GothamBold,
        TextSize = 13,
        TextXAlignment = Enum.TextXAlignment.Left,
        ZIndex = 52,
    }, card)

    New("TextLabel", {
        Position = UDim2.new(0, 44, 0, 30),
        Size = UDim2.new(1, -52, 0, 26),
        BackgroundTransparency = 1,
        Text = message,
        TextColor3 = C.TextSecondary,
        Font = Enum.Font.Gotham,
        TextSize = 11,
        TextXAlignment = Enum.TextXAlignment.Left,
        TextWrapped = true,
        ZIndex = 52,
    }, card)

    -- Progress bar
    local prog = New("Frame", {
        BackgroundColor3 = color,
        BorderSizePixel = 0,
        Position = UDim2.new(0, 0, 1, -2),
        Size = UDim2.new(1, 0, 0, 2),
        ZIndex = 52,
    }, card)

    -- Slide in
    card.Position = UDim2.new(1.1, 0, 0, 0)
    Aether.Tween(card, 0.3, Enum.EasingStyle.Back, Enum.EasingDirection.Out, { Position = UDim2.new(0, 0, 0, 0) })
    Aether.Tween(prog, duration, Enum.EasingStyle.Linear, Enum.EasingDirection.Out, { Size = UDim2.new(0, 0, 0, 2) })

    task.delay(duration, function()
        if card and card.Parent then
            Aether.Tween(card, 0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.In, {
                Position = UDim2.new(1.1, 0, 0, 0),
                BackgroundTransparency = 1,
            })
            task.delay(0.3, function() if card and card.Parent then card:Destroy() end end)
        end
    end)
end

-- ─── Utilities ───────────────────────────────────────────────────────────────
-- FIX: SetStatus auto-reverts after 3s
function Aether:SetStatus(text, color, autoRevert)
    if not (self._statusLabel and self._statusLabel.Parent) then return end
    self._statusLabel.Text       = "● " .. (text or "Ready")
    self._statusLabel.TextColor3 = color or C.Success

    if autoRevert ~= false then
        if self._statusRevertTask then task.cancel(self._statusRevertTask) end
        self._statusRevertTask = task.delay(3, function()
            if self._statusLabel and self._statusLabel.Parent then
                self._statusLabel.Text       = "● Ready"
                self._statusLabel.TextColor3 = C.Success
            end
        end)
    end
end

function Aether:Minimize()
    if not self._isVisible then return end
    self._isVisible = false
    self._savedPosition = self._main.Position

    Aether.Tween(self._main, 0.28, Enum.EasingStyle.Quad, Enum.EasingDirection.In, {
        Position = UDim2.new(self._main.Position.X.Scale, self._main.Position.X.Offset, 1.15, 0),
        BackgroundTransparency = 1,
    })
    Aether.Tween(self._backdrop, 0.2, nil, nil, { BackgroundTransparency = 1 })
    Aether.Tween(self._shadow,   0.2, nil, nil, { ImageTransparency = 1 })
    task.delay(0.3, function()
        if self._main and self._main.Parent then self._main.Visible = false end
    end)
end

-- FIX: Toggle restore correctly uses saved position
function Aether:Toggle()
    if self._isVisible then
        self:Minimize()
    else
        self._isVisible = true
        self._main.Visible = true
        self._main.Position = UDim2.new(
            (self._savedPosition or UDim2.fromScale(0.5, 0.5)).X.Scale,
            (self._savedPosition or UDim2.fromScale(0.5, 0.5)).X.Offset,
            1.15, 0
        )
        self._main.BackgroundTransparency = 1

        Aether.Tween(self._backdrop, 0.22, nil, nil, { BackgroundTransparency = 0.55 })
        Aether.Tween(self._shadow,   0.3,  nil, nil, { ImageTransparency = 0.35 })
        Aether.Tween(self._main, 0.3, Enum.EasingStyle.Back, Enum.EasingDirection.Out, {
            Position = self._savedPosition or UDim2.fromScale(0.5, 0.5),
            BackgroundTransparency = 0,
        })
    end
end

function Aether:Destroy()
    for _, conn in ipairs(self._connections) do
        pcall(function() conn:Disconnect() end)
    end
    if self._root and self._root.Parent then
        self._root:Destroy()
    end
end

