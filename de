-- TAB
-- ═══════════════════════════════════════════════════════════════════════════════
function Aether:Tab(name, icon)
    icon = icon or ""
    local tabData = { name = name, sections = {} }
    table.insert(self._tabs, tabData)

    -- Tab button
    local tabBtn = New("TextButton", {
        BackgroundColor3     = C.Surface,
        BackgroundTransparency = 1,
        BorderSizePixel      = 0,
        Size                 = UDim2.new(1, 0, 0, 34),
        Font                 = Enum.Font.Gotham,
        Text                 = (icon ~= "" and icon .. "  " or "") .. name,
        TextColor3           = C.TextMuted,
        TextSize             = 12,
        TextXAlignment       = Enum.TextXAlignment.Left,
        ZIndex               = 8,
        AutoButtonColor      = false,
        LayoutOrder          = #self._tabs,
    }, self._tabList)
    New("UIPadding", { PaddingLeft = UDim.new(0, 10) }, tabBtn)
    New("UICorner", { CornerRadius = UDim.new(0, 6) }, tabBtn)

    local indicator = New("Frame", {
        BackgroundColor3 = C.AccentOrange,
        BorderSizePixel  = 0,
        Position         = UDim2.new(0, 0, 0.5, -10),
        Size             = UDim2.new(0, 2, 0, 20),
        ZIndex           = 9,
        BackgroundTransparency = 1,
    }, tabBtn)
    New("UICorner", { CornerRadius = UDim.new(0, 2) }, indicator)

    -- Scroll frame for content
    local scroll = New("ScrollingFrame", {
        BackgroundTransparency = 1,
        BorderSizePixel        = 0,
        Size                   = UDim2.new(1, 0, 1, 0),
        CanvasSize             = UDim2.new(0, 0, 0, 0),
        AutomaticCanvasSize    = Enum.AutomaticSize.Y,
        ScrollBarThickness     = 2,
        ScrollBarImageColor3   = C.Border,
        ScrollingDirection     = Enum.ScrollingDirection.Y,
        ZIndex                 = 4,
        Visible                = false,
    }, self._contentArea)
    New("UIPadding", { PaddingTop = UDim.new(0, 12), PaddingBottom = UDim.new(0, 12), PaddingLeft = UDim.new(0, 12), PaddingRight = UDim.new(0, 12) }, scroll)

    local innerList = New("Frame", {
        BackgroundTransparency = 1,
        Size                   = UDim2.new(1, 0, 0, 0),
        AutomaticSize          = Enum.AutomaticSize.Y,
        ZIndex                 = 5,
    }, scroll)
    New("UIListLayout", { SortOrder = Enum.SortOrder.LayoutOrder, Padding = UDim.new(0, 10) }, innerList)

    tabData.btn      = tabBtn
    tabData.indicator = indicator
    tabData.scroll   = scroll
    tabData.inner    = innerList

    local function activate()
        -- Deactivate others
        for _, t in ipairs(self._tabs) do
            if t ~= tabData then
                Tween(t.btn, 0.18, nil, nil, { TextColor3 = C.TextMuted, BackgroundTransparency = 1 })
                Tween(t.indicator, 0.18, nil, nil, { BackgroundTransparency = 1 })
                t.scroll.Visible = false
            end
        end
        self._activeTab = tabData
        Tween(tabBtn, 0.18, nil, nil, { TextColor3 = C.TextPrimary, BackgroundTransparency = 0.85 })
        Tween(indicator, 0.18, nil, nil, { BackgroundTransparency = 0 })
        scroll.Visible = true
    end

    tabBtn.MouseButton1Click:Connect(activate)
    tabBtn.MouseEnter:Connect(function()
        if self._activeTab ~= tabData then
            Tween(tabBtn, 0.15, nil, nil, { TextColor3 = C.TextSecondary, BackgroundTransparency = 0.93 })
        end
    end)
    tabBtn.MouseLeave:Connect(function()
        if self._activeTab ~= tabData then
            Tween(tabBtn, 0.15, nil, nil, { TextColor3 = C.TextMuted, BackgroundTransparency = 1 })
        end
    end)

    -- Auto-select first tab
    if #self._tabs == 1 then activate() end

    -- ── Tab API (fluent builder)
