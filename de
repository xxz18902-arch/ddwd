        TextSize               = 14,
        TextXAlignment         = Enum.TextXAlignment.Left,
        TextTruncate           = Enum.TextTruncate.AtEnd,
        ZIndex                 = 16,
    }, card)

    local trackSub = New("TextLabel", {
        BackgroundTransparency = 1,
        Position               = UDim2.new(0, infoX, 0, 38),
        Size                   = UDim2.new(1, -(infoX + 12), 0, 16),
        Font                   = Enum.Font.Gotham,
        Text                   = "Add tracks to start",
        TextColor3             = C.TextSecondary,
        TextSize               = 11,
        TextXAlignment         = Enum.TextXAlignment.Left,
        TextTruncate           = Enum.TextTruncate.AtEnd,
        ZIndex                 = 16,
    }, card)

    -- Progress bar
    local progBg = New("Frame", {
        BackgroundColor3 = C.Border,
        BorderSizePixel  = 0,
        Position         = UDim2.new(0, infoX, 0, 68),
        Size             = UDim2.new(1, -(infoX + 12), 0, 5),
        ZIndex           = 16,
    }, card)
    New("UICorner", { CornerRadius = UDim.new(1, 0) }, progBg)

    local progFill = New("Frame", {
        BackgroundColor3 = C.AccentOrange,
        BorderSizePixel  = 0,
        Size             = UDim2.new(0, 0, 1, 0),
        ZIndex           = 17,
    }, progBg)
    New("UICorner", { CornerRadius = UDim.new(1, 0) }, progFill)
    New("UIGradient", {
        Color = ColorSequence.new({
            ColorSequenceKeypoint.new(0, C.AccentOrange),
            ColorSequenceKeypoint.new(1, C.AccentPurple),
        }),
    }, progFill)

    -- Progress scrubbing
    local scrubbing = false
    progBg.InputBegan:Connect(function(input)
        if input.UserInputType ~= Enum.UserInputType.MouseButton1 then return end
        scrubbing = true
        if mp._sound and mp._sound.TimeLength > 0 then
            local sc = math.clamp((input.Position.X - progBg.AbsolutePosition.X) / progBg.AbsoluteSize.X, 0, 1)
            mp._sound.TimePosition = sc * mp._sound.TimeLength
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if not scrubbing then return end
        if input.UserInputType == Enum.UserInputType.MouseMovement then
            if mp._sound and mp._sound.TimeLength > 0 then
                local sc = math.clamp((input.Position.X - progBg.AbsolutePosition.X) / progBg.AbsoluteSize.X, 0, 1)
                mp._sound.TimePosition = sc * mp._sound.TimeLength
            end
        end
    end)
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then scrubbing = false end
    end)

    local timeLabel = New("TextLabel", {
        BackgroundTransparency = 1,
        Position               = UDim2.new(0, infoX, 0, 78),
        Size                   = UDim2.new(1, -(infoX + 12), 0, 14),
        Font                   = Enum.Font.Gotham,
        Text                   = "0:00 / 0:00",
        TextColor3             = C.TextMuted,
        TextSize               = 10,
        TextXAlignment         = Enum.TextXAlignment.Left,
        ZIndex                 = 16,
    }, card)

    -- Controls
    local ctrlX = infoX

    local function makeCtrl(label, posX, sz, primary, cb)
        sz = sz or 34
        local bg = primary and C.AccentOrange or C.SurfaceHover
        local b = New("TextButton", {
            BackgroundColor3 = bg,
            BorderSizePixel  = 0,
            Position         = UDim2.new(0, ctrlX + posX, 0, 100),
            Size             = UDim2.new(0, sz, 0, sz),
            Font             = Enum.Font.GothamBold,
            Text             = label,
            TextColor3       = C.TextPrimary,
            TextSize         = 13,
            ZIndex           = 17,
            AutoButtonColor  = false,
        }, card)
        New("UICorner", { CornerRadius = UDim.new(0, 7) }, b)
        if primary then
            New("UIGradient", {
                Color = ColorSequence.new({
                    ColorSequenceKeypoint.new(0, C.AccentOrange),
                    ColorSequenceKeypoint.new(1, C.AccentPurple),
                }),
            }, b)
        end
        b.MouseEnter:Connect(function()
            Tween(b, 0.15, nil, nil, { BackgroundColor3 = primary and C.AccentPurple or C.SurfaceActive })
        end)
        b.MouseLeave:Connect(function()
            Tween(b, 0.15, nil, nil, { BackgroundColor3 = bg })
        end)
        b.MouseButton1Click:Connect(cb)
        return b
    end

    makeCtrl("◄◄", 0, 30, false, function() mp:Prev() end)
    local playBtn = makeCtrl("▶",  36, 36, true,  function() mp:TogglePlay() end)
    makeCtrl("■",  78, 30, false, function() mp:Stop() end)
    makeCtrl("►►", 114, 30, false, function() mp:Next() end)

    -- Volume
    New("TextLabel", {
        BackgroundTransparency = 1,
        Position               = UDim2.new(0, infoX, 0, 148),
        Size                   = UDim2.new(1, -(infoX + 12), 0, 14),
        Font                   = Enum.Font.Gotham,
        Text                   = "VOLUME",
        TextColor3             = C.TextMuted,
        TextSize               = 9,
        TextXAlignment         = Enum.TextXAlignment.Left,
        ZIndex                 = 16,
    }, card)

    local volPct = New("TextLabel", {
        BackgroundTransparency = 1,
        Position               = UDim2.new(1, -44, 0, 148),
        Size                   = UDim2.new(0, 40, 0, 14),
        Font                   = Enum.Font.Gotham,
        Text                   = "50%",
        TextColor3             = C.TextSecondary,
        TextSize               = 9,
        TextXAlignment         = Enum.TextXAlignment.Right,
        ZIndex                 = 16,
    }, card)

    local volTrack = New("Frame", {
        BackgroundColor3 = C.Border,
        BorderSizePixel  = 0,
        Position         = UDim2.new(0, infoX, 0, 166),
        Size             = UDim2.new(1, -(infoX + 12), 0, 5),
        ZIndex           = 16,
    }, card)
    New("UICorner", { CornerRadius = UDim.new(1, 0) }, volTrack)

    local volFill = New("Frame", {
        BackgroundColor3 = C.AccentOrange,
        BorderSizePixel  = 0,
        Size             = UDim2.new(0.5, 0, 1, 0),
        ZIndex           = 17,
    }, volTrack)
    New("UICorner", { CornerRadius = UDim.new(1, 0) }, volFill)

    local volThumb = New("Frame", {
        BackgroundColor3 = Color3.new(1, 1, 1),
        BorderSizePixel  = 0,
        Position         = UDim2.new(0.5, -6, 0.5, -6),
        Size             = UDim2.new(0, 12, 0, 12),
        ZIndex           = 18,
    }, volTrack)
    New("UICorner", { CornerRadius = UDim.new(1, 0) }, volThumb)

    local volDragging = false
    local function updateVol(input)
        local sc = math.clamp((input.Position.X - volTrack.AbsolutePosition.X) / volTrack.AbsoluteSize.X, 0, 1)
        volFill.Size = UDim2.new(sc, 0, 1, 0)
        volThumb.Position = UDim2.new(sc, -6, 0.5, -6)
        volPct.Text = math.floor(sc * 100) .. "%"
        if mp._sound then mp._sound.Volume = sc end
    end
    volThumb.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then volDragging = true end
    end)
    UserInputService.InputEnded:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then volDragging = false end
    end)
    UserInputService.InputChanged:Connect(function(i)
        if volDragging and i.UserInputType == Enum.UserInputType.MouseMovement then updateVol(i) end
    end)
    volTrack.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then updateVol(i) end
    end)

    -- ── Playlist
    New("TextLabel", {
        BackgroundTransparency = 1,
        Position               = UDim2.new(0, 14, 0, 185),
        Size                   = UDim2.new(1, -28, 0, 14),
        Font                   = Enum.Font.GothamBold,
        Text                   = "PLAYLIST",
        TextColor3             = C.TextMuted,
        TextSize               = 9,
        TextXAlignment         = Enum.TextXAlignment.Left,
        ZIndex                 = 16,
    }, card)

    local playlistScroll = New("ScrollingFrame", {
        BackgroundColor3     = C.Background,
        BorderSizePixel      = 0,
        Position             = UDim2.new(0, 14, 0, 202),
        Size                 = UDim2.new(1, -28, 0, 102),
        CanvasSize           = UDim2.new(0, 0, 0, 0),
        AutomaticCanvasSize  = Enum.AutomaticSize.Y,
        ScrollBarThickness   = 2,
        ScrollBarImageColor3 = C.Border,
        ScrollingDirection   = Enum.ScrollingDirection.Y,
        ZIndex               = 16,
    }, card)
    New("UICorner", { CornerRadius = UDim.new(0, 5) }, playlistScroll)
    New("UIListLayout", { SortOrder = Enum.SortOrder.LayoutOrder, Padding = UDim.new(0, 1) }, playlistScroll)
    New("UIPadding", { PaddingTop = UDim.new(0, 4), PaddingBottom = UDim.new(0, 4) }, playlistScroll)

    -- Add-track input row
    local addRow = New("Frame", {
        BackgroundTransparency = 1,
        Position               = UDim2.new(0, 14, 1, -14),
        AnchorPoint            = Vector2.new(0, 1),
        Size                   = UDim2.new(1, -28, 0, 26),
        ZIndex                 = 16,
    }, card)

    local addBox = New("TextBox", {
        BackgroundColor3 = C.Background,
        BorderSizePixel  = 0,
        Size             = UDim2.new(1, -62, 1, 0),
        Font             = Enum.Font.Gotham,
        Text             = "",
        PlaceholderText  = "Asset ID or rbxassetid://...",
        PlaceholderColor3 = C.TextMuted,
        TextColor3       = C.TextPrimary,
        TextSize         = 11,
        ClearTextOnFocus = false,
        ZIndex           = 17,
    }, addRow)
    New("UICorner", { CornerRadius = UDim.new(0, 4) }, addBox)
    New("UIStroke", { Color = C.Border, Thickness = 1 }, addBox)
    New("UIPadding", { PaddingLeft = UDim.new(0, 6) }, addBox)

    local addBtn = New("TextButton", {
        BackgroundColor3 = C.AccentOrange,
        BorderSizePixel  = 0,
        Position         = UDim2.new(1, -58, 0, 0),
        Size             = UDim2.new(0, 56, 1, 0),
        Font             = Enum.Font.GothamBold,
        Text             = "+ Add",
        TextColor3       = C.TextPrimary,
        TextSize         = 11,
        ZIndex           = 17,
        AutoButtonColor  = false,
    }, addRow)
    New("UICorner", { CornerRadius = UDim.new(0, 4) }, addBtn)
    addBtn.MouseEnter:Connect(function() Tween(addBtn, 0.15, nil, nil, { BackgroundColor3 = C.AccentPurple }) end)
    addBtn.MouseLeave:Connect(function() Tween(addBtn, 0.15, nil, nil, { BackgroundColor3 = C.AccentOrange }) end)

    -- ── Internal music-player methods
    local function refreshPlaylist()
        for _, child in ipairs(playlistScroll:GetChildren()) do
            if child:IsA("Frame") then child:Destroy() end
        end
        for idx, track in ipairs(mp._playlist) do
            local row = New("Frame", {
                BackgroundColor3 = (idx == mp._current) and C.SurfaceActive or C.Surface,
                BackgroundTransparency = (idx == mp._current) and 0 or 1,
                BorderSizePixel  = 0,
                Size             = UDim2.new(1, -8, 0, 28),
                ZIndex           = 17,
                LayoutOrder      = idx,
            }, playlistScroll)
            New("UICorner", { CornerRadius = UDim.new(0, 4) }, row)

            local numLbl = New("TextLabel", {
                BackgroundTransparency = 1,
                Position               = UDim2.new(0, 8, 0, 0),
                Size                   = UDim2.new(0, 18, 1, 0),
                Font                   = Enum.Font.GothamBold,
                Text                   = tostring(idx),
                TextColor3             = (idx == mp._current) and C.AccentOrange or C.TextMuted,
                TextSize               = 10,
                ZIndex                 = 18,
            }, row)

            local nameLbl = New("TextLabel", {
                BackgroundTransparency = 1,
                Position               = UDim2.new(0, 30, 0, 0),
                Size                   = UDim2.new(1, -60, 1, 0),
                Font                   = Enum.Font.Gotham,
                Text                   = track.name,
                TextColor3             = (idx == mp._current) and C.TextPrimary or C.TextSecondary,
                TextSize               = 11,
                TextXAlignment         = Enum.TextXAlignment.Left,
                TextTruncate           = Enum.TextTruncate.AtEnd,
                ZIndex                 = 18,
            }, row)

            -- Delete button per track
            local delBtn = New("TextButton", {
                BackgroundTransparency = 1,
                Position               = UDim2.new(1, -24, 0.5, -8),
                Size                   = UDim2.new(0, 16, 0, 16),
                Font                   = Enum.Font.GothamBold,
                Text                   = "×",
                TextColor3             = C.TextMuted,
                TextSize               = 14,
                ZIndex                 = 19,
                AutoButtonColor        = false,
            }, row)
            delBtn.MouseEnter:Connect(function() delBtn.TextColor3 = C.Danger end)
            delBtn.MouseLeave:Connect(function() delBtn.TextColor3 = C.TextMuted end)
            delBtn.MouseButton1Click:Connect(function()
                table.remove(mp._playlist, idx)
                if mp._current >= idx then
                    mp._current = math.max(1, mp._current - 1)
                end
                refreshPlaylist()
            end)

            -- Click row to jump to track
            local clickArea = New("TextButton", {
                BackgroundTransparency = 1,
                Size                   = UDim2.new(1, -28, 1, 0),
                Text                   = "",
                ZIndex                 = 19,
                AutoButtonColor        = false,
            }, row)
            clickArea.MouseButton1Click:Connect(function()
                mp._current = idx
                mp:LoadCurrent()
                mp:Play()
            end)

            row.MouseEnter:Connect(function()
                if idx ~= mp._current then
                    Tween(row, 0.12, nil, nil, { BackgroundTransparency = 0.85 })
                end
            end)
            row.MouseLeave:Connect(function()
                if idx ~= mp._current then
                    Tween(row, 0.12, nil, nil, { BackgroundTransparency = 1 })
                end
            end)
        end

        if #mp._playlist == 0 then
            New("TextLabel", {
                BackgroundTransparency = 1,
                Size                   = UDim2.new(1, 0, 0, 40),
                Font                   = Enum.Font.Gotham,
                Text                   = "Playlist empty. Add a track above.",
                TextColor3             = C.TextMuted,
                TextSize               = 11,
                ZIndex                 = 17,
            }, playlistScroll)
        end
    end

    function mp:LoadCurrent()
        local track = self._playlist[self._current]
        if not track then return end

        -- Clean up old sound
        if self._sound then
            self._sound:Stop()
            self._sound:Destroy()
            self._sound = nil
        end

        local s = Instance.new("Sound")
        s.SoundId   = track.id
        s.Volume    = tonumber(volPct.Text:match("%d+")) / 100 or 0.5
        s.Looped    = false
        s.Parent    = game:GetService("SoundService")
        self._sound = s

        s.Loaded:Wait()
        trackTitle.Text = track.name
        trackSub.Text   = "rbxassetid://" .. track.rawId

        s.Ended:Connect(function()
            self:Next()
        end)

        refreshPlaylist()
    end

    function mp:Play()
        if not self._sound then return end
        self._playing = true
        self._sound:Play()
        playBtn.Text = "⏸"

        -- Heartbeat: update progress + visualizer
        if self._heartbeat then self._heartbeat:Disconnect() end
        self._heartbeat = RunService.Heartbeat:Connect(function()
            if not self._sound or not self._playing then return end
            local dur = self._sound.TimeLength
            local pos = self._sound.TimePosition
            if dur > 0 then
                progFill.Size = UDim2.new(pos / dur, 0, 1, 0)
                timeLabel.Text = FormatTime(pos) .. " / " .. FormatTime(dur)
            end

            -- Animate bars
            for i, bar in ipairs(bars) do
                local h = math.random(4, 70)
                Tween(bar, 0.08, Enum.EasingStyle.Sine, nil, { Size = UDim2.new(0, 5, 0, h) })
            end
        end)
    end

    function mp:Stop()
        if self._sound then self._sound:Stop() end
        self._playing = false
        playBtn.Text = "▶"
        progFill.Size = UDim2.new(0, 0, 1, 0)
        timeLabel.Text = "0:00 / 0:00"
        if self._heartbeat then self._heartbeat:Disconnect(); self._heartbeat = nil end
        for _, bar in ipairs(bars) do
            Tween(bar, 0.3, nil, nil, { Size = UDim2.new(0, 5, 0, 2) })
        end
    end

    function mp:TogglePlay()
        if self._playing then
            self._sound:Pause()
            self._playing = false
            playBtn.Text = "▶"
            if self._heartbeat then self._heartbeat:Disconnect(); self._heartbeat = nil end
        else
            if self._sound then
                self:Play()
            elseif #self._playlist > 0 then
                self._current = 1
                self:LoadCurrent()
                self:Play()
            end
        end
    end

    function mp:Next()
        if #self._playlist == 0 then return end
        self._current = (self._current % #self._playlist) + 1
        self:LoadCurrent()
        if self._playing then self:Play() end
    end

    function mp:Prev()
        if #self._playlist == 0 then return end
        self._current = ((self._current - 2) % #self._playlist) + 1
        self:LoadCurrent()
        if self._playing then self:Play() end
    end

    function mp:AddTrack(id, name)
        -- Normalise ID
        local rawId = tostring(id):match("%d+") or tostring(id)
        local soundId = "rbxassetid://" .. rawId
        name = name or ("Track " .. (#self._playlist + 1))
        table.insert(self._playlist, { id = soundId, rawId = rawId, name = name })
        if self._current == 0 then self._current = 1 end
        refreshPlaylist()
    end

    -- Add-track button action
    addBtn.MouseButton1Click:Connect(function()
        local raw = addBox.Text
        if raw == "" then return end
        mp:AddTrack(raw, "Track " .. (#mp._playlist + 1))
        addBox.Text = ""
    end)
    addBox.FocusLost:Connect(function(enter)
        if enter then
            local raw = addBox.Text
            if raw ~= "" then
                mp:AddTrack(raw, "Track " .. (#mp._playlist + 1))
                addBox.Text = ""
            end
        end
    end)

    refreshPlaylist()

    return mp
end

