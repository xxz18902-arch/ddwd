-- MUSIC PLAYER  (full rewrite — fixed all original bugs)
-- ═══════════════════════════════════════════════════════════════════════════════
function Aether:MusicPlayer(parentTab)
    -- parentTab should be a Tab returned by :Tab(); it expects a Section named "Music Player"
    -- Falls back to embedding directly in the window's contentArea if nil.
    local targetContent
    if parentTab then
        local sec = parentTab:Section("Music Player")
        -- sec is the content Frame (UIPadding + UIListLayout inside)
        targetContent = sec
    else
        targetContent = self._contentArea
    end

    local mp = {}
    mp._playlist    = {}
    mp._current     = 0
    mp._playing     = false
    mp._sound       = nil
    mp._heartbeat   = nil

    -- Container card
    local card = New("Frame", {
        BackgroundColor3 = C.Surface,
        BorderSizePixel  = 0,
        Size             = UDim2.new(1, 0, 0, 320),
        ZIndex           = 15,
        ClipsDescendants = false,
    }, targetContent)
    New("UICorner", { CornerRadius = UDim.new(0, 8) }, card)
