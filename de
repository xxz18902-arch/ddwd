-- CORE HELPERS
-- ═══════════════════════════════════════════════════════════════════════════════
local function Tween(inst, dur, style, dir, props)
    local info = TweenInfo.new(
        dur or 0.2,
        style or Enum.EasingStyle.Quad,
        dir or Enum.EasingDirection.Out
    )
    local t = TweenService:Create(inst, info, props)
    t:Play()
    return t
end

local function New(class, props, parent)
    local obj = Instance.new(class)
    for k, v in pairs(props or {}) do
        obj[k] = v
    end
    if parent then obj.Parent = parent end
    return obj
end

-- Expose on module for external use
Aether.Tween = Tween
Aether.New   = New

-- Ripple effect on click
local function Ripple(parent, mx, my)
    local rel_x = mx - parent.AbsolutePosition.X
    local rel_y = my - parent.AbsolutePosition.Y
    local r = New("Frame", {
        Name                 = "Ripple",
        BackgroundColor3     = Color3.new(1, 1, 1),
        BackgroundTransparency = 0.75,
        BorderSizePixel      = 0,
        Position             = UDim2.new(0, rel_x - 6, 0, rel_y - 6),
        Size                 = UDim2.new(0, 12, 0, 12),
        ZIndex               = parent.ZIndex + 10,
        ClipsDescendants     = false,
    }, parent)
    New("UICorner", { CornerRadius = UDim.new(1, 0) }, r)
    local maxD = math.max(parent.AbsoluteSize.X, parent.AbsoluteSize.Y) * 2.8
    Tween(r, 0.55, Enum.EasingStyle.Quad, Enum.EasingDirection.Out, {
        Size                 = UDim2.new(0, maxD, 0, maxD),
        BackgroundTransparency = 1,
        Position             = UDim2.new(0, rel_x - maxD / 2, 0, rel_y - maxD / 2),
    })
    task.delay(0.6, function() if r and r.Parent then r:Destroy() end end)
end

-- Safe ScreenGui parent (supports most executors)
local function SafeGui(name)
    local sg = Instance.new("ScreenGui")
    sg.Name            = name or "AetherUI"
    sg.ResetOnSpawn    = false
    sg.ZIndexBehavior  = Enum.ZIndexBehavior.Sibling
    sg.IgnoreGuiInset  = true

    if gethui then
        sg.Parent = gethui()
    elseif syn and syn.protect_gui then
        syn.protect_gui(sg)
        sg.Parent = game:GetService("CoreGui")
    else
        local ok, cg = pcall(function() return game:GetService("CoreGui") end)
        sg.Parent = ok and cg or LocalPlayer:WaitForChild("PlayerGui")
    end
    return sg
end

-- Format seconds → M:SS
local function FormatTime(s)
    s = math.floor(s or 0)
    return string.format("%d:%02d", math.floor(s / 60), s % 60)
end

-- ═══════════════════════════════════════════════════════════════════════════════
-- NOTIFICATION SYSTEM (standalone, spawned to top-right)
-- ═══════════════════════════════════════════════════════════════════════════════
local notifGui   = nil
local notifStack = {}
local NOTIF_W    = 300
local NOTIF_GAP  = 10
local NOTIF_PAD  = 16

local function getNotifGui()
    if notifGui and notifGui.Parent then return notifGui end
    notifGui = SafeGui("AetherNotifs")
    return notifGui
end

local function rebuildNotifPositions()
    local y = NOTIF_GAP
    for _, f in ipairs(notifStack) do
        if f and f.Parent then
            Tween(f, 0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.Out, {
                Position = UDim2.new(1, -(NOTIF_W + NOTIF_GAP), 0, y)
            })
            y = y + f.AbsoluteSize.Y + NOTIF_GAP
        end
    end
end

function Aether.Notification(title, body, duration, ntype)
    duration = duration or 4
    ntype = ntype or "info"

    local accentColor = ntype == "success" and C.Success
                     or ntype == "warn"    and C.Warning
                     or ntype == "danger"  and C.Danger
                     or C.AccentBlue

    local gui = getNotifGui()

    -- Outer card
    local card = New("Frame", {
        BackgroundColor3     = C.Surface,
        BorderSizePixel      = 0,
        Position             = UDim2.new(1, NOTIF_GAP, 0, NOTIF_GAP),  -- offscreen right
        Size                 = UDim2.new(0, NOTIF_W, 0, 0),
        AutomaticSize        = Enum.AutomaticSize.Y,
        ZIndex               = 50,
        ClipsDescendants     = false,
    }, gui)
    New("UICorner", { CornerRadius = UDim.new(0, 8) }, card)
    New("UIStroke", { Color = C.Border, Thickness = 1, ApplyStrokeMode = Enum.ApplyStrokeMode.Border }, card)

    -- Accent left bar
    New("Frame", {
        BackgroundColor3 = accentColor,
        BorderSizePixel  = 0,
        Position         = UDim2.new(0, 0, 0, 0),
        Size             = UDim2.new(0, 3, 1, 0),
        ZIndex           = 51,
    }, card)

    -- Inner padding container
    local inner = New("Frame", {
        BackgroundTransparency = 1,
        Position               = UDim2.new(0, NOTIF_PAD, 0, 0),
        Size                   = UDim2.new(1, -NOTIF_PAD, 0, 0),
        AutomaticSize          = Enum.AutomaticSize.Y,
        ZIndex                 = 51,
    }, card)
    New("UIListLayout", { SortOrder = Enum.SortOrder.LayoutOrder, Padding = UDim.new(0, 4) }, inner)
    New("UIPadding", { PaddingTop = UDim.new(0, 10), PaddingBottom = UDim.new(0, 10) }, inner)

    -- Title row
    local titleRow = New("Frame", {
        BackgroundTransparency = 1,
        Size                   = UDim2.new(1, 0, 0, 20),
        LayoutOrder            = 0,
        ZIndex                 = 52,
    }, inner)

    New("TextLabel", {
        BackgroundTransparency = 1,
        Size                   = UDim2.new(1, -28, 1, 0),
        Font                   = Enum.Font.GothamBold,
        Text                   = title or "Notice",
        TextColor3             = accentColor,
        TextSize               = 13,
        TextXAlignment         = Enum.TextXAlignment.Left,
        ZIndex                 = 53,
    }, titleRow)

    -- Close button
    local closeBtn = New("TextButton", {
        BackgroundTransparency = 1,
        Position               = UDim2.new(1, -24, 0.5, -8),
        Size                   = UDim2.new(0, 16, 0, 16),
        Font                   = Enum.Font.GothamBold,
        Text                   = "×",
        TextColor3             = C.TextMuted,
        TextSize               = 16,
        ZIndex                 = 54,
        AutoButtonColor        = false,
    }, titleRow)

    -- Body text (optional)
    if body and body ~= "" then
        New("TextLabel", {
            BackgroundTransparency = 1,
            Size                   = UDim2.new(1, 0, 0, 0),
            AutomaticSize          = Enum.AutomaticSize.Y,
            Font                   = Enum.Font.Gotham,
            Text                   = body,
            TextColor3             = C.TextSecondary,
            TextSize               = 12,
            TextXAlignment         = Enum.TextXAlignment.Left,
            TextWrapped            = true,
            LayoutOrder            = 1,
            ZIndex                 = 52,
        }, inner)
    end

    -- Progress bar
    local progBg = New("Frame", {
        BackgroundColor3 = C.Border,
        BorderSizePixel  = 0,
        Size             = UDim2.new(1, 0, 0, 2),
        LayoutOrder      = 2,
        ZIndex           = 52,
    }, inner)
    New("UICorner", { CornerRadius = UDim.new(1, 0) }, progBg)
    local progFill = New("Frame", {
        BackgroundColor3 = accentColor,
        BorderSizePixel  = 0,
        Size             = UDim2.new(1, 0, 1, 0),
        ZIndex           = 53,
    }, progBg)
    New("UICorner", { CornerRadius = UDim.new(1, 0) }, progFill)

    -- Add to stack
    table.insert(notifStack, card)

    -- Slide in
    task.defer(function()
        rebuildNotifPositions()
        Tween(card, 0.3, Enum.EasingStyle.Back, Enum.EasingDirection.Out, {
            Position = UDim2.new(1, -(NOTIF_W + NOTIF_GAP), 0, NOTIF_GAP)
        })
    end)

    -- Timer + progress bar countdown
    local function dismiss()
        Tween(card, 0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.In, {
            Position = UDim2.new(1, NOTIF_GAP, 0, card.Position.Y.Offset),
            BackgroundTransparency = 1,
        })
        task.delay(0.35, function()
            if card and card.Parent then card:Destroy() end
            for i, f in ipairs(notifStack) do
                if f == card then table.remove(notifStack, i) break end
            end
            rebuildNotifPositions()
        end)
    end

    closeBtn.MouseButton1Click:Connect(dismiss)

    -- Animate progress bar to zero over duration
    Tween(progFill, duration, Enum.EasingStyle.Linear, Enum.EasingDirection.Out, {
        Size = UDim2.new(0, 0, 1, 0)
    })
    task.delay(duration, dismiss)
end

-- ═══════════════════════════════════════════════════════════════════════════════
-- MAIN WINDOW CONSTRUCTOR
-- ═══════════════════════════════════════════════════════════════════════════════
function Aether.new(config)
    config = config or {}
    local self      = setmetatable({}, Aether)
    self._tabs      = {}
    self._activeTab = nil
    self._hidden    = false
    self._dragging  = false

    local title    = config.Title    or "Aether UI"
    local subtitle = config.Subtitle or "v2.0"
    local accent   = config.Accent   or C.AccentOrange
    local toggleKey = config.ToggleKey or Enum.KeyCode.RightShift

    -- ── ScreenGui
    local sg = SafeGui("AetherUI_" .. title)
    self._gui = sg

    -- ── Main window frame
    local WIN_W = 560
    local WIN_H = 480

    local win = New("Frame", {
        Name             = "Window",
        BackgroundColor3 = C.Background,
        BorderSizePixel  = 0,
        Position         = UDim2.new(0.5, -WIN_W / 2, 0.5, -WIN_H / 2),
        Size             = UDim2.new(0, WIN_W, 0, WIN_H),
        ZIndex           = 1,
        ClipsDescendants = false,
    }, sg)
    New("UICorner", { CornerRadius = UDim.new(0, 10) }, win)
    New("UIStroke", { Color = C.Border, Thickness = 1.2, ApplyStrokeMode = Enum.ApplyStrokeMode.Border }, win)
    self._win = win

    -- Drop shadow (cosmetic frame behind the window)
    local shadow = New("Frame", {
        BackgroundColor3     = Color3.new(0, 0, 0),
        BackgroundTransparency = 0.55,
        BorderSizePixel      = 0,
        Position             = UDim2.new(0, -8, 0, -8),
        Size                 = UDim2.new(1, 16, 1, 16),
        ZIndex               = 0,
    }, win)
    New("UICorner", { CornerRadius = UDim.new(0, 14) }, shadow)

    -- ── Top bar
    local topBar = New("Frame", {
        Name             = "TopBar",
        BackgroundColor3 = C.Surface,
        BorderSizePixel  = 0,
        Size             = UDim2.new(1, 0, 0, 48),
        ZIndex           = 5,
    }, win)
    New("UICorner", { CornerRadius = UDim.new(0, 10) }, topBar)

    -- Cover bottom corners of topBar
    New("Frame", {
        BackgroundColor3 = C.Surface,
        BorderSizePixel  = 0,
        Position         = UDim2.new(0, 0, 0.5, 0),
        Size             = UDim2.new(1, 0, 0.5, 0),
        ZIndex           = 5,
    }, topBar)

    -- Accent gradient line at top
    local accentLine = New("Frame", {
        BackgroundColor3 = accent,
        BorderSizePixel  = 0,
        Position         = UDim2.new(0, 0, 0, 0),
        Size             = UDim2.new(1, 0, 0, 2),
        ZIndex           = 6,
    }, win)
    New("UICorner", { CornerRadius = UDim.new(0, 10) }, accentLine)
    New("UIGradient", {
        Color = ColorSequence.new({
            ColorSequenceKeypoint.new(0, accent),
            ColorSequenceKeypoint.new(0.5, C.AccentPurple),
            ColorSequenceKeypoint.new(1, C.AccentBlue),
        }),
        Rotation = 0,
    }, accentLine)

    -- Title text
    New("TextLabel", {
        BackgroundTransparency = 1,
        Position               = UDim2.new(0, 16, 0, 0),
        Size                   = UDim2.new(0.6, 0, 1, 0),
        Font                   = Enum.Font.GothamBold,
        Text                   = title,
        TextColor3             = C.TextPrimary,
        TextSize               = 15,
        TextXAlignment         = Enum.TextXAlignment.Left,
        ZIndex                 = 8,
    }, topBar)

    -- Subtitle badge
    local subtitleBadge = New("Frame", {
        BackgroundColor3 = C.SurfaceHover,
        BorderSizePixel  = 0,
        Position         = UDim2.new(0, 16 + string.len(title) * 9, 0.5, -9),
        Size             = UDim2.new(0, string.len(subtitle) * 7 + 12, 0, 18),
        ZIndex           = 8,
    }, topBar)
    New("UICorner", { CornerRadius = UDim.new(0, 4) }, subtitleBadge)
    New("UIStroke", { Color = C.Border, Thickness = 1 }, subtitleBadge)
    New("TextLabel", {
        BackgroundTransparency = 1,
        Size                   = UDim2.new(1, 0, 1, 0),
        Font                   = Enum.Font.Gotham,
        Text                   = subtitle,
        TextColor3             = C.TextMuted,
        TextSize               = 10,
        ZIndex                 = 9,
    }, subtitleBadge)

    -- Window controls (×, −)
    local function makeWinCtrl(symbol, xOff, color, cb)
        local btn = New("TextButton", {
            BackgroundColor3 = color,
            BorderSizePixel  = 0,
            Position         = UDim2.new(1, xOff, 0.5, -8),
            Size             = UDim2.new(0, 16, 0, 16),
            Font             = Enum.Font.GothamBold,
            Text             = "",
            ZIndex           = 10,
            AutoButtonColor  = false,
        }, topBar)
        New("UICorner", { CornerRadius = UDim.new(1, 0) }, btn)
        local lbl = New("TextLabel", {
            BackgroundTransparency = 1,
            Size                   = UDim2.new(1, 0, 1, 0),
            Font                   = Enum.Font.GothamBold,
            Text                   = symbol,
            TextColor3             = Color3.new(0, 0, 0),
            TextSize               = 11,
            TextTransparency       = 1,
            ZIndex                 = 11,
        }, btn)
        btn.MouseEnter:Connect(function()
            Tween(lbl, 0.15, nil, nil, { TextTransparency = 0 })
            Tween(btn, 0.15, nil, nil, { BackgroundColor3 = color:lerp(Color3.new(1,1,1), 0.25) })
        end)
        btn.MouseLeave:Connect(function()
            Tween(lbl, 0.15, nil, nil, { TextTransparency = 1 })
            Tween(btn, 0.15, nil, nil, { BackgroundColor3 = color })
        end)
        btn.MouseButton1Click:Connect(cb)
        return btn
    end

    makeWinCtrl("×", -14, Color3.fromRGB(255, 96, 89), function()
        Tween(win, 0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.In, {
            Size = UDim2.new(0, WIN_W, 0, 0),
            BackgroundTransparency = 1,
        })
        task.delay(0.28, function() sg:Destroy() end)
    end)
    makeWinCtrl("−", -36, Color3.fromRGB(255, 189, 68), function()
        self._hidden = not self._hidden
        if self._hidden then
            Tween(win, 0.22, Enum.EasingStyle.Quad, Enum.EasingDirection.In, {
                Size = UDim2.new(0, WIN_W, 0, 48)
            })
        else
            Tween(win, 0.28, Enum.EasingStyle.Back, Enum.EasingDirection.Out, {
                Size = UDim2.new(0, WIN_W, 0, WIN_H)
            })
        end
    end)

    -- Drag
    local dragStart, dragOrigin
    topBar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            self._dragging = true
            dragStart  = input.Position
            dragOrigin = win.Position
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if self._dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            local delta = input.Position - dragStart
            win.Position = UDim2.new(
                dragOrigin.X.Scale, dragOrigin.X.Offset + delta.X,
                dragOrigin.Y.Scale, dragOrigin.Y.Offset + delta.Y
            )
        end
    end)
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            self._dragging = false
        end
    end)

    -- Toggle visibility hotkey
    UserInputService.InputBegan:Connect(function(input, gpe)
        if gpe then return end
        if input.KeyCode == toggleKey then
            self._hidden = not self._hidden
            win.Visible = not self._hidden
        end
    end)

    -- ── Tab bar
    local tabBar = New("Frame", {
        Name             = "TabBar",
        BackgroundTransparency = 1,
        Position         = UDim2.new(0, 0, 0, 48),
        Size             = UDim2.new(0, 130, 1, -48),
        ZIndex           = 3,
        ClipsDescendants = false,
    }, win)

    local tabList = New("Frame", {
        BackgroundTransparency = 1,
        Size                   = UDim2.new(1, 0, 0, 0),
        AutomaticSize          = Enum.AutomaticSize.Y,
        ZIndex                 = 4,
    }, tabBar)
    New("UIListLayout", { SortOrder = Enum.SortOrder.LayoutOrder, Padding = UDim.new(0, 2) }, tabList)
    New("UIPadding", { PaddingTop = UDim.new(0, 10), PaddingLeft = UDim.new(0, 8), PaddingRight = UDim.new(0, 8) }, tabList)

    -- Separator between tab bar and content
    New("Frame", {
        BackgroundColor3 = C.Border,
        BorderSizePixel  = 0,
        Position         = UDim2.new(0, 128, 0, 48),
        Size             = UDim2.new(0, 1, 1, -48),
        ZIndex           = 3,
    }, win)

    -- ── Content area
    local contentArea = New("Frame", {
        Name             = "ContentArea",
        BackgroundTransparency = 1,
        Position         = UDim2.new(0, 130, 0, 48),
        Size             = UDim2.new(1, -130, 1, -48),
        ClipsDescendants = true,
        ZIndex           = 3,
    }, win)

    self._tabList    = tabList
    self._contentArea = contentArea

    -- ── Entrance animation
    win.Size = UDim2.new(0, WIN_W, 0, 0)
    win.BackgroundTransparency = 1
    task.defer(function()
        Tween(win, 0.35, Enum.EasingStyle.Back, Enum.EasingDirection.Out, {
            Size = UDim2.new(0, WIN_W, 0, WIN_H),
            BackgroundTransparency = 0,
        })
    end)

    return self
end

